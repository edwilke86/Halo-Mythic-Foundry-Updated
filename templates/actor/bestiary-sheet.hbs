              <label>
                Size
                <select name="system.bestiary.size">
                  {{#each sizeOptions as |opt|}}
                    <option value="{{opt.value}}"{{#if opt.selected}} selected{{/if}}>{{opt.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>Height Min (cm)<input type="number" min="0" step="1" name="system.bestiary.heightRangeCm.min" value="{{system.bestiary.heightRangeCm.min}}" /></label>
              <label>Height Max (cm)<input type="number" min="0" step="1" name="system.bestiary.heightRangeCm.max" value="{{system.bestiary.heightRangeCm.max}}" /></label>
              <label>Weight Min (kg)<input type="number" min="0" step="1" name="system.bestiary.weightRangeKg.min" value="{{system.bestiary.weightRangeKg.min}}" /></label>
              <label>Weight Max (kg)<input type="number" min="0" step="1" name="system.bestiary.weightRangeKg.max" value="{{system.bestiary.weightRangeKg.max}}" /></label>
              <label>Jump Multiplier<input type="number" step="0.1" name="system.bestiary.modifiers.jumpMultiplier" value="{{system.bestiary.modifiers.jumpMultiplier}}" /></label>
              <label>Leap AGI Bonus<input type="number" step="1" name="system.bestiary.modifiers.leapAgiBonus" value="{{system.bestiary.modifiers.leapAgiBonus}}" /></label>
              <label>Leap Multiplier<input type="number" step="0.1" name="system.bestiary.modifiers.leapMultiplier" value="{{system.bestiary.modifiers.leapMultiplier}}" /></label>
              <label>AGI Bonus Run/Charge<input type="number" step="1" name="system.bestiary.modifiers.runChargeAgiBonus" value="{{system.bestiary.modifiers.runChargeAgiBonus}}" /></label>
              <label>Natural Armor<input type="number" step="1" name="system.bestiary.modifiers.naturalArmor" value="{{system.bestiary.modifiers.naturalArmor}}" /></label>
            </div>
          </section>

          <section class="mythic-bestiary-panel">
            <h2>Equipped Armor <span class="mythic-drop-hint">(drop an armor item to equip)</span></h2>
            {{#if bestiaryEquippedArmor}}
              <div class="mythic-bestiary-equipped-armor">
                <div class="mythic-bestiary-armor-header">
                  <img class="mythic-bestiary-embedded-img" src="{{bestiaryEquippedArmor.img}}" alt="{{bestiaryEquippedArmor.name}}" />
                  <span class="mythic-bestiary-armor-name">{{bestiaryEquippedArmor.name}}</span>
                  {{#if bestiaryEquippedArmor.isFloodHalved}}<span class="mythic-bestiary-flood-halved">(½ Flood DR)</span>{{/if}}
                  <button type="button" class="mythic-bestiary-armor-remove" data-bestiary-unequip-armor="{{bestiaryEquippedArmor.id}}" title="Remove armor">Remove</button>
                </div>
                <div class="mythic-bestiary-armor-dr-grid">
                  <div class="mythic-bestiary-armor-dr-row"><span class="mythic-bestiary-armor-dr-label">Head</span><span class="mythic-bestiary-armor-dr-value">{{bestiaryEquippedArmor.head}}</span></div>
                  <div class="mythic-bestiary-armor-dr-row"><span class="mythic-bestiary-armor-dr-label">Chest</span><span class="mythic-bestiary-armor-dr-value">{{bestiaryEquippedArmor.chest}}</span></div>
                  <div class="mythic-bestiary-armor-dr-row"><span class="mythic-bestiary-armor-dr-label">Arms</span><span class="mythic-bestiary-armor-dr-value">{{bestiaryEquippedArmor.arms}}</span></div>
                  <div class="mythic-bestiary-armor-dr-row"><span class="mythic-bestiary-armor-dr-label">Legs</span><span class="mythic-bestiary-armor-dr-value">{{bestiaryEquippedArmor.legs}}</span></div>
                  {{#if bestiaryEquippedArmor.shieldIntegrity}}
                    <div class="mythic-bestiary-armor-dr-row"><span class="mythic-bestiary-armor-dr-label">Shield</span><span class="mythic-bestiary-armor-dr-value">{{bestiaryEquippedArmor.shieldIntegrity}}</span></div>
                  {{/if}}
                </div>
              </div>
            {{else}}
              <p class="mythic-empty-state">No armor equipped. Drop an armor item to equip it.</p>
            {{/if}}
          </section>

          <section class="mythic-bestiary-panel mythic-sheet-appearance-panel">
            <h2>Sheet Appearance</h2>
            {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/sheet-appearance-fields.hbs"}}
          </section>
        </section>
        {{/if}}
      </div>
    </div>
  </section>
</div>
