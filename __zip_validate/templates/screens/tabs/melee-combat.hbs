<div class="gm-screen-grid">

  <article class="gm-panel">
    <h2>Amount of Melee Attacks Turn</h2>
    <div class="gm-source-ref core">Ref: p.30</div>

    <div class="gm-callout">
      <div>
        The base amount of Melee Attacks a creature can make in a Half
        Action is equal to half of their Warfare Melee Modifier, to a minimum
        of 1. If a creature’s Warfare Melee is 40, they can make 2 Attacks per
        Half Action.
      </div>
    </div>
  </article>


  <article class="gm-panel">
    <h2>Improvised Weapon Damage</h2>
    <div class="gm-source-ref core">Ref: p.36</div>

    <table class="gm-ref-table">
      <thead>
        <tr>
          <th>Weight</th>
          <th>Outcome</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">Under 1 kg</th>
          <td>The Attack counts as the Punch Melee Attack.</td>
        </tr>
        <tr>
          <th scope="row">Up to 5kg</th>
          <td>2D10 + Half Strength Modifier + half Weight (kg)</td>
        </tr>
        <tr>
          <th scope="row">Up to 10kg</th>
          <td>3D10 + Half Strength Modifier + half Weight (kg)</td>
        </tr>
        <tr>
          <th scope="row">Over 10kg</th>
          <td>4D10 + Half Strength Modifier + half Weight (kg)</td>
        </tr>
      </tbody>
    </table>
  </article>


  <article class="gm-panel">
    <h2>Throwing Distance (STR Mod + Mythic STR)</h2>
    <div class="gm-source-ref core">Ref: p.36</div>

    <table class="gm-ref-table">
      <thead>
        <tr>
          <th>Modifier</th>
          <th>Weight and Outcome</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">1-2</th>
          <td>Every 0.1KG lowers the Multiplier by 2.</td>
        </tr>
        <tr>
          <th scope="row">3-4</th>
          <td>Every 0.1KG lowers the Multiplier by 1.</td>
        </tr>
        <tr>
          <th scope="row">5-6</th>
          <td>Every 0.2KG lowers the Multiplier by 1.</td>
        </tr>
        <tr>
          <th scope="row">7-9</th>
          <td>Every 0.5KG lowers the Multiplier by 1.</td>
        </tr>
        <tr>
          <th scope="row">10-12</th>
          <td>Every 1KG lowers the Multiplier by 1.</td>
        </tr>
        <tr>
          <th scope="row">13-18</th>
          <td>Every 5KG lowers the Multiplier by 1.</td>
        </tr>
        <tr>
          <th scope="row">19-25</th>
          <td>Every 10KG lowers the Multiplier by 1.</td>
        </tr>
      </tbody>
    </table>
  </article>

</div>