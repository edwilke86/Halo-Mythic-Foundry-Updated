{
  "id": "Halo-Mythic-Foundry-Updated",
  "title": "Halo Mythic Foundry Updated",
  "description": "Community Foundry VTT system project for the Halo Mythic ruleset.",
  "version": "0.1.0-alpha.1",
  "license": "SEE LICENSE and LICENSE.assets",
  "compatibility": {
    "minimum": 13,
    "verified": 13.351
  },
  "authors": [
    {
      "discord": "Neoshain",
      "name": "Dallas Scott Wilke",
      "url": "https://github.com/edwilke86"
    }
  ],
  "grid": {
    "units": "m",
    "distance": 1
  },
  "esmodules": [
    "system.mjs"
  ],
  "styles": [
    "styles/system.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": [
          "biography.physical.generalDescription",
          "biography.physical.definingFeatures"
        ]
      }
    },
    "Item": {
      "gear": {},
      "soldierType": {
        "htmlFields": [
          "description",
          "notes"
        ]
      },
      "trait": {
        "htmlFields": [
          "shortDescription",
          "benefit",
          "notes"
        ]
      },
      "education": {
        "htmlFields": [
          "description"
        ]
      },
      "ability": {
        "htmlFields": [
          "prerequisiteText",
          "shortDescription",
          "benefit",
          "notes"
        ]
      },
      "armorVariant": {
        "htmlFields": [
          "description",
          "notes"
        ]
      }
    }
  },
  "packs": [
    {
      "name": "educations",
      "label": "Educations",
      "path": "packs/educations",
      "type": "Item",
      "system": "Halo-Mythic-Foundry-Updated",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER",
        "GAMEMASTER": "OWNER"
      }
    },
    {
      "name": "abilities",
      "label": "Abilities",
      "path": "packs/abilities",
      "type": "Item",
      "system": "Halo-Mythic-Foundry-Updated",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER",
        "GAMEMASTER": "OWNER"
      }
    }
  ],
  
  "primaryTokenAttribute": { "attribute": "system.combat.wounds" },
  "secondaryTokenAttribute": { "attribute": "system.combat.shields" },
  "socket": false
}
