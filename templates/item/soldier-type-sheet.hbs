<div class="{{cssClass}} mythic-ability-item-sheet mythic-soldier-type-sheet">
  <header class="ability-sheet-header">
    <img class="ability-sheet-icon" src="{{item.img}}" title="{{item.name}}" alt="{{item.name}}" />
    <div class="ability-sheet-header-text">
      <h2 class="ability-sheet-title">{{item.name}}</h2>
      <div class="ability-sheet-meta">
        {{#if editable}}
          <button type="button" class="action-btn mythic-toggle-edit-btn">{{#if canEditFields}}Lock{{else}}Edit{{/if}}</button>
        {{/if}}
        <span class="ability-page-badge">Soldier Type Template</span>
      </div>
    </div>
  </header>

  <section class="ability-sheet-body">
    <div class="ability-info-row">
      <label for="soldier-name">Name</label>
      <input id="soldier-name" type="text" name="name" value="{{item.name}}" {{#unless canEditFields}}disabled{{/unless}} />
    </div>

    <div class="ability-info-row ability-notes-row">
      <label for="soldier-description">Description</label>
      <textarea id="soldier-description" name="system.description" rows="3" {{#unless canEditFields}}disabled{{/unless}}>{{soldierType.description}}</textarea>
    </div>

    <div class="ability-grid-3">
      <div class="ability-info-row ability-col">
        <label for="soldier-header-type">Soldier Type</label>
        <input id="soldier-header-type" type="text" name="name" value="{{item.name}}" {{#unless canEditFields}}disabled{{/unless}} />
      </div>
      <div class="ability-info-row ability-col">
        <label for="soldier-header-rank">Rank</label>
        <input id="soldier-header-rank" type="text" name="system.header.rank" value="{{soldierType.header.rank}}" {{#unless canEditFields}}disabled{{/unless}} />
      </div>
      <div class="ability-info-row ability-col">
        <label>Specialisation</label>
        <span class="muted-text">Removed</span>
      </div>
    </div>

    <div class="ability-grid-3">
      <div class="ability-info-row ability-col">
        <label>Allowed Upbringing (drop Upbringing items)</label>
        <div id="allowed-upbringing-dropzone" class="soldier-type-drop-zone" data-kind="upbringing">{{#each soldierType.ruleFlags.allowedUpbringings.upbringings}}<span class="drop-tag" data-value="{{this}}">{{this}} ×</span>{{/each}}</div>
        <textarea id="soldier-allowed-upbringing" name="mythic.allowedUpbringingsText" rows="2" style="display:none;">{{#each soldierType.ruleFlags.allowedUpbringings.upbringings}}{{this}}\n{{/each}}</textarea>
      </div>
      <div class="ability-info-row ability-col">
        <label>Allowed Environment (drop Environment items)</label>
        <div id="allowed-environment-dropzone" class="soldier-type-drop-zone" data-kind="environment">{{#each soldierType.ruleFlags.allowedEnvironments.environments}}<span class="drop-tag" data-value="{{this}}">{{this}} ×</span>{{/each}}</div>
        <textarea id="soldier-allowed-environment" name="mythic.allowedEnvironmentsText" rows="2" style="display:none;">{{#each soldierType.ruleFlags.allowedEnvironments.environments}}{{this}}\n{{/each}}</textarea>
      </div>
      <div class="ability-info-row ability-col">
        <label>Allowed Lifestyle (drop Lifestyle items)</label>
        <div id="allowed-lifestyle-dropzone" class="soldier-type-drop-zone" data-kind="lifestyle">{{#each soldierType.ruleFlags.allowedLifestyles.lifestyles}}<span class="drop-tag" data-value="{{this}}">{{this}} ×</span>{{/each}}</div>
        <textarea id="soldier-allowed-lifestyle" name="mythic.allowedLifestylesText" rows="2" style="display:none;">{{#each soldierType.ruleFlags.allowedLifestyles.lifestyles}}{{this}}\n{{/each}}</textarea>
      </div>
    </div>

    <div class="ability-grid-5">
      <div class="ability-info-row ability-col"><label for="soldier-char-str">STR</label><input id="soldier-char-str" type="number" min="0" step="1" name="system.characteristics.str" value="{{soldierType.characteristics.str}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-char-tou">TOU</label><input id="soldier-char-tou" type="number" min="0" step="1" name="system.characteristics.tou" value="{{soldierType.characteristics.tou}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-char-agi">AGI</label><input id="soldier-char-agi" type="number" min="0" step="1" name="system.characteristics.agi" value="{{soldierType.characteristics.agi}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-char-wfm">WFM</label><input id="soldier-char-wfm" type="number" min="0" step="1" name="system.characteristics.wfm" value="{{soldierType.characteristics.wfm}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-char-wfr">WFR</label><input id="soldier-char-wfr" type="number" min="0" step="1" name="system.characteristics.wfr" value="{{soldierType.characteristics.wfr}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
    </div>

    <div class="ability-grid-5">
      <div class="ability-info-row ability-col"><label for="soldier-char-int">INT</label><input id="soldier-char-int" type="number" min="0" step="1" name="system.characteristics.int" value="{{soldierType.characteristics.int}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-char-per">PER</label><input id="soldier-char-per" type="number" min="0" step="1" name="system.characteristics.per" value="{{soldierType.characteristics.per}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-char-crg">CRG</label><input id="soldier-char-crg" type="number" min="0" step="1" name="system.characteristics.crg" value="{{soldierType.characteristics.crg}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-char-cha">CHA</label><input id="soldier-char-cha" type="number" min="0" step="1" name="system.characteristics.cha" value="{{soldierType.characteristics.cha}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-char-ldr">LDR</label><input id="soldier-char-ldr" type="number" min="0" step="1" name="system.characteristics.ldr" value="{{soldierType.characteristics.ldr}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
    </div>
    <div class="ability-grid-3">
      <div class="ability-info-row ability-col"><label for="soldier-mythic-str">Mythic STR</label><input id="soldier-mythic-str" type="number" min="0" step="1" name="system.mythic.str" value="{{soldierType.mythic.str}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-mythic-tou">Mythic TOU</label><input id="soldier-mythic-tou" type="number" min="0" step="1" name="system.mythic.tou" value="{{soldierType.mythic.tou}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
      <div class="ability-info-row ability-col"><label for="soldier-mythic-agi">Mythic AGI</label><input id="soldier-mythic-agi" type="number" min="0" step="1" name="system.mythic.agi" value="{{soldierType.mythic.agi}}" {{#unless canEditFields}}disabled{{/unless}} /></div>
    </div>

    <div class="ability-info-row ability-notes-row">
      <label>Granted Abilities (drop Ability items)</label>
      <div id="abilities-dropzone" class="soldier-type-drop-zone">{{#each soldierType.abilities}}<span class="drop-tag" data-value="{{this}}">{{this}} ×</span>{{/each}}</div>
      <textarea id="soldier-abilities" name="mythic.abilitiesText" rows="3" style="display:none;">{{#each soldierType.abilities}}{{this}}\n{{/each}}</textarea>
    </div>

    <div class="ability-info-row ability-notes-row">
      <label>Granted Traits (drop Trait items)</label>
      <div id="traits-dropzone" class="soldier-type-drop-zone">{{#each soldierType.traits}}<span class="drop-tag" data-value="{{this}}">{{this}} ×</span>{{/each}}</div>
      <textarea id="soldier-traits" name="mythic.traitsText" rows="3" style="display:none;">{{#each soldierType.traits}}{{this}}\n{{/each}}</textarea>
    </div>

    <div class="ability-info-row ability-notes-row">
      <label>Training Options</label>
      <div class="ability-grid-4">
        {{#each trainingOptions}}
          <div class="ability-col"><label><input type="checkbox" name="mythic.trainingOptions" value="{{this.value}}" {{#if this.checked}}checked{{/if}} {{#unless canEditFields}}disabled{{/unless}} /> {{this.label}}</label></div>
        {{/each}}
      </div>
    </div>

    <div class="ability-grid-3">
      <div class="ability-info-row ability-col">
        <label for="skill-choice-count">Skills Choosen</label>
        <input id="skill-choice-count" type="number" min="0" step="1" name="mythic.skillChoiceCount" value="{{skillChoice.count}}" {{#unless canEditFields}}disabled{{/unless}} />
      </div>
      <div class="ability-info-row ability-col">
        <label for="skill-choice-tier">Skill Tier</label>
        <select id="skill-choice-tier" name="mythic.skillChoiceTier" {{#unless canEditFields}}disabled{{/unless}}>
          <option value="trained" {{#if skillChoice.isTrained}}selected{{/if}}>Trained</option>
          <option value="+10" {{#if skillChoice.isPlus10}}selected{{/if}}>+10</option>
          <option value="+20" {{#if skillChoice.isPlus20}}selected{{/if}}>+20</option>
        </select>
      </div>
      <div class="ability-info-row ability-col">
        <label for="education-choice-count">Educations Choosen</label>
        <input id="education-choice-count" type="number" min="0" step="1" name="mythic.educationChoiceCount" value="{{educationChoice.count}}" {{#unless canEditFields}}disabled{{/unless}} />
      </div>
    </div>

    <div class="ability-grid-3">
      <div class="ability-info-row ability-col">
        <label for="education-choice-tier">Education Tier</label>
        <select id="education-choice-tier" name="mythic.educationChoiceTier" {{#unless canEditFields}}disabled{{/unless}}>
          <option value="+5" {{#if educationChoice.isPlus5}}selected{{/if}}>+5</option>
          <option value="+10" {{#if educationChoice.isPlus10}}selected{{/if}}>+10</option>
        </select>
      </div>
      <div class="ability-info-row ability-col" style="grid-column: span 2;">
        <label for="custom-prompt-messages">Custom Prompt Messages (one per line)</label>
        <textarea id="custom-prompt-messages" name="mythic.customPromptMessagesText" rows="3" {{#unless canEditFields}}disabled{{/unless}}>{{customPromptMessagesText}}</textarea>
      </div>
    </div>

    <div class="ability-info-row ability-notes-row">
      <label for="soldier-notes">Notes</label>
      <textarea id="soldier-notes" name="system.notes" rows="4" {{#unless canEditFields}}disabled{{/unless}}>{{soldierType.notes}}</textarea>
    </div>
  </section>
</div>
