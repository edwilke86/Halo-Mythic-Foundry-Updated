      </div>
    </div>
    <div class="ability-grid-3">
      <div class="ability-info-row ability-col">
        <label for="armor-mod-ldr">LDR</label>
        <input id="armor-mod-ldr" type="number" step="1" name="system.characteristicMods.base.ldr"
          value="{{gear.characteristicMods.base.ldr}}" {{#unless canEditFields}}disabled{{/unless}} />
      </div>
    </div>
    <p class="gear-tab-section-label">Mythic Characteristics</p>
    <div class="ability-grid-3">
      <div class="ability-info-row ability-col">
        <label for="armor-mod-mythic-str">Mythic STR</label>
        <input id="armor-mod-mythic-str" type="number" step="1" name="system.characteristicMods.mythic.str"
