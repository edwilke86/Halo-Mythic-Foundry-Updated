<div class="tab notes" data-group="primary" data-tab="notes">
  <section class="panel mythic-phase4-panel">
    <h2>Notes</h2>

    <div class="mythic-phase4-grid two-column">
      <div class="mythic-phase4-card">
        <h3>Mission Log</h3>
        <textarea name="system.notes.missionLog" rows="10">{{mythicSystem.notes.missionLog}}</textarea>
      </div>

      <div class="mythic-phase4-card">
        <h3>Personal Notes</h3>
        <textarea name="system.notes.personalNotes" rows="10">{{mythicSystem.notes.personalNotes}}</textarea>
      </div>
    </div>

    <div class="mythic-phase4-card full-width">
      <h3>GM / Hidden Notes</h3>
      <textarea name="system.notes.gmNotes" rows="8">{{mythicSystem.notes.gmNotes}}</textarea>
    </div>
  </section>
</div>