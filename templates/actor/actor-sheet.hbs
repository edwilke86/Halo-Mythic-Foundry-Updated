{{#if mythicIsVehicleActor}}
<div class="{{cssClass}} mythic-character-sheet mythic-bestiary-shell mythic-vehicle-fallback-sheet" data-faction="{{mythicFactionIndex}}">
  <aside class="sheet-nav">
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item" data-tab="vehicle-summary" title="Vehicle Summary">
        <i class="fas fa-truck"></i>
      </a>
      <a class="item" data-tab="vehicle-crew" title="Crew & Complement">
        <i class="fas fa-users"></i>
      </a>
      <a class="item" data-tab="vehicle-cargo" title="Cargo">
        <i class="fas fa-boxes-stacked"></i>
      </a>
      <a class="item" data-tab="vehicle-notes" title="Notes">
        <i class="fas fa-note-sticky"></i>
      </a>
      <a class="item" data-tab="vehicle-settings" title="Settings">
        <i class="fas fa-gear"></i>
      </a>
    </nav>
  </aside>

  <section class="sheet-content">
    <header class="mythic-bestiary-header mythic-bestiary-sticky-header mythic-sticky-header panel">
      <div class="mythic-bestiary-portrait-wrap">
        <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}" />
      </div>
      <div class="mythic-bestiary-header-fields">
        <div class="mythic-bestiary-header-title-row">
          <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Vehicle Name" /></h1>
          <div class="mythic-bestiary-header-xp-field">
            <label>Defeat Experience</label>
            <input type="number" name="system.defeatExperience" value="{{mythicVehicleSystem.defeatExperience}}" />
          </div>
        </div>
        <div class="mythic-bestiary-header-grid">
          <label>
            Nickname
            <input type="text" name="system.designation" value="{{mythicVehicleSystem.designation}}" />
          </label>
          <label>
            Variant
            <input type="text" name="system.variant" value="{{mythicVehicleSystem.variant}}" />
          </label>
          <label>
            Faction
            <select name="system.faction">
              <option value=""{{#unless mythicVehicleSystem.faction}} selected{{/unless}}></option>
              {{selectOptions mythicFactionSelectOptions selected=mythicVehicleSystem.faction}}
            </select>
          </label>
          <label>
            Price
            <input type="number" name="system.price" value="{{mythicVehicleSystem.price}}" />
          </label>
        </div>
        <div class="mythic-bestiary-header-dimensions" style="margin-top:8px; display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:8px;">
          <label>
            Length (m)
            <input type="number" name="system.dimensions.length" value="{{mythicVehicleSystem.dimensions.length}}" />
          </label>
          <label>
            Width (m)
            <input type="number" name="system.dimensions.width" value="{{mythicVehicleSystem.dimensions.width}}" />
          </label>
          <label>
            Height (m)
            <input type="number" name="system.dimensions.height" value="{{mythicVehicleSystem.dimensions.height}}" />
          </label>
          <label>
            Weight (t)
            <input type="number" name="system.dimensions.weight" value="{{mythicVehicleSystem.dimensions.weight}}" />
          </label>
        </div>
      </div>
    </header>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-summary" style="padding:14px 16px;">
      <div class="vehicle-summary-grid">
        <aside class="panel vehicle-mobility">
          <h2>Mobility</h2>
          <div class="mobility-row">
            <label>Current Speed</label>
            <div class="mobility-value" data-field="system.mythicVehicleSystem.movement.speed.value">{{mythicVehicleSystem.movement.speed.value}}</div>
            <div class="mobility-controls">
              <button class="action-btn" type="button" data-action="decrease-speed">−</button>
              <button class="action-btn" type="button" data-action="increase-speed">+</button>
            </div>
          </div>
          <div class="mobility-row">
            <label>Brake</label>
            <div class="mobility-value" data-field="system.mythicVehicleSystem.movement.brake.value">{{mythicVehicleSystem.movement.brake.value}}</div>
          </div>
          <div class="mobility-row">
            <label>Accelerate</label>
            <div class="mobility-value" data-field="system.mythicVehicleSystem.movement.accelerate.value">{{mythicVehicleSystem.movement.accelerate.value}}</div>
          </div>
          <div class="mobility-row">
            <label>Maneuver</label>
            <div class="mobility-value" data-field="system.mythicVehicleSystem.movement.maneuver.total">{{mythicVehicleSystem.movement.maneuver.total}}</div>
          </div>
          <div class="mobility-actions">
            <button class="action-btn" type="button" data-action="splatter">Splatter</button>
            <button class="action-btn" type="button" data-action="wreck">Wreck</button>
          </div>
        </aside>

        <div class="panel vehicle-summary-main">
          <h2>Overview</h2>
          <p><!-- Placeholder for summary visuals (breakpoints, armor, shields, weapons preview) --></p>
        </div>
      </div>
    </div>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-crew" style="padding:14px 16px;">
      <div class="panel">
        <h2>Crew & Complement</h2>
        <div class="crew-section">
          <h3>Operators</h3>
          <div class="crew-list">
            {{#each mythicVehicleSystem.crew.operators}}
              <div class="crew-slot mythic-crew-dropzone" data-kind="operators" data-idx="{{idx}}">
                <div class="crew-label">Operator {{slotNumber}}:</div>
                {{#if id}}
                  <div class="crew-name">{{display}} <span class="crew-type">({{#if isPC}}PC{{else}}NPC{{/if}})</span></div>
                  <button type="button" class="crew-clear-btn" data-kind="operators" data-idx="{{idx}}">Clear</button>
                {{else}}
                  <div class="crew-empty">Empty — drop actor</div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>

        <div class="crew-section" style="margin-top:12px;">
          <h3>Gunners</h3>
          <div class="crew-list">
            {{#each mythicVehicleSystem.crew.gunners}}
              <div class="crew-slot mythic-crew-dropzone" data-kind="gunners" data-idx="{{idx}}">
                <div class="crew-label">Gunner {{slotNumber}}:</div>
                {{#if id}}
                  <div class="crew-name">{{display}} <span class="crew-type">({{#if isPC}}PC{{else}}NPC{{/if}})</span></div>
                  <button type="button" class="crew-clear-btn" data-kind="gunners" data-idx="{{idx}}">Clear</button>
                {{else}}
                  <div class="crew-empty">Empty — drop actor</div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>

        <div class="crew-section" style="margin-top:12px;">
          <h3>Passengers</h3>
          <div class="crew-list">
            {{#each mythicVehicleSystem.crew.complement}}
              <div class="crew-slot mythic-crew-dropzone" data-kind="complement" data-idx="{{idx}}">
                <div class="crew-label">Passenger {{slotNumber}}:</div>
                {{#if id}}
                  <div class="crew-name">{{display}} <span class="crew-type">({{#if isPC}}PC{{else}}NPC{{/if}})</span></div>
                  <button type="button" class="crew-clear-btn" data-kind="complement" data-idx="{{idx}}">Clear</button>
                {{else}}
                  <div class="crew-empty">Empty — drop actor</div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>
      </div>
    </div>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-cargo" style="padding:14px 16px;">
      <!-- Vehicle Cargo tab cleared. Add cargo controls here when ready. -->
    </div>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-notes" style="padding:14px 16px;">
      <!-- Vehicle Notes tab cleared. -->
    </div>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-settings" style="padding:14px 16px;">
      <div class="panel">
        <h2>Setup</h2>
        <div class="setup-grid">
          <div class="panel breakpoints-panel">
            <h3>Breakpoints</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">WEP</div><input class="small-input" type="number" name="system.breakpoints.wep.value" value="{{mythicVehicleSystem.breakpoints.wep.value}}" /></div>
              <div class="compact-field"><div class="field-label">MOB</div><input class="small-input" type="number" name="system.breakpoints.mob.value" value="{{mythicVehicleSystem.breakpoints.mob.value}}" /></div>
              <div class="compact-field"><div class="field-label">ENG</div><input class="small-input" type="number" name="system.breakpoints.eng.value" value="{{mythicVehicleSystem.breakpoints.eng.value}}" /></div>
              <div class="compact-field"><div class="field-label">OP</div><input class="small-input" type="number" name="system.breakpoints.op.value" value="{{mythicVehicleSystem.breakpoints.op.value}}" /></div>
              <div class="compact-field"><div class="field-label">HULL</div><input class="small-input" type="number" name="system.breakpoints.hull.value" value="{{mythicVehicleSystem.breakpoints.hull.value}}" /></div>
            </div>
          </div>

          <div class="panel armor-panel">
            <h3>Armor</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Front</div><input class="small-input" type="number" name="system.armor.front.value" value="{{mythicVehicleSystem.armor.front.value}}" /></div>
              <div class="compact-field"><div class="field-label">Back</div><input class="small-input" type="number" name="system.armor.back.value" value="{{mythicVehicleSystem.armor.back.value}}" /></div>
              <div class="compact-field"><div class="field-label">Side</div><input class="small-input" type="number" name="system.armor.side.value" value="{{mythicVehicleSystem.armor.side.value}}" /></div>
              <div class="compact-field"><div class="field-label">Top</div><input class="small-input" type="number" name="system.armor.top.value" value="{{mythicVehicleSystem.armor.top.value}}" /></div>
              <div class="compact-field"><div class="field-label">Bottom</div><input class="small-input" type="number" name="system.armor.bottom.value" value="{{mythicVehicleSystem.armor.bottom.value}}" /></div>
            </div>
          </div>

          <div class="panel shields-panel">
            <h3>Shields</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Integrity</div><input class="small-input" type="number" name="system.shields.value" value="{{mythicVehicleSystem.shields.value}}" /></div>
              <div class="compact-field"><div class="field-label">Delay</div><input class="small-input" type="number" name="system.shields.delay" value="{{mythicVehicleSystem.shields.delay}}" /></div>
              <div class="compact-field"><div class="field-label">Recharge</div><input class="small-input" type="number" name="system.shields.recharge" value="{{mythicVehicleSystem.shields.recharge}}" /></div>
            </div>
          </div>

          <div class="panel movement-panel">
            <h3>Movement</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Accelerate</div><input class="small-input" type="number" name="system.movement.accelerate.value" value="{{mythicVehicleSystem.movement.accelerate.value}}" /></div>
              <div class="compact-field"><div class="field-label">Brake</div><input class="small-input" type="number" name="system.movement.brake.value" value="{{mythicVehicleSystem.movement.brake.value}}" /></div>
              <div class="compact-field"><div class="field-label">Top Speed</div><input class="small-input" type="number" name="system.movement.speed.value" value="{{mythicVehicleSystem.movement.speed.value}}" /></div>
              <div class="compact-field"><div class="field-label">Maneuver</div><input class="small-input" type="number" name="system.movement.maneuver.total" value="{{mythicVehicleSystem.movement.maneuver.total}}" /></div>
            </div>
          </div>

          <div class="panel propulsion-panel">
            <h3>Propulsion</h3>
            <div class="compact-row">
              <div style="min-width:160px;">
                <label>Type
                  <select name="system.propulsion.type">
                    <option value="none" {{#if (eq mythicVehicleSystem.propulsion.type "none")}}selected{{/if}}>Stationary</option>
                    <option value="legs" {{#if (eq mythicVehicleSystem.propulsion.type "legs")}}selected{{/if}}>Legs</option>
                    <option value="thrusters" {{#if (eq mythicVehicleSystem.propulsion.type "thrusters")}}selected{{/if}}>Thrusters</option>
                    <option value="treads" {{#if (eq mythicVehicleSystem.propulsion.type "treads")}}selected{{/if}}>Treads</option>
                    <option value="wheels" {{#if (eq mythicVehicleSystem.propulsion.type "wheels")}}selected{{/if}}>Wheels</option>
                  </select>
                </label>
              </div>
              <div class="compact-field"><div class="field-label">Intact</div><input class="small-input" type="number" name="system.propulsion.value" value="{{mythicVehicleSystem.propulsion.value}}" /></div>
              <div class="compact-field"><div class="field-label">Total</div><input class="small-input" type="number" name="system.propulsion.max" value="{{mythicVehicleSystem.propulsion.max}}" /></div>
            </div>
          </div>

          <div class="panel size-panel">
            <h3>Size and Weapon Points</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Size</div>
                <input class="small-input" type="number" name="system.sizePoints" value="{{mythicVehicleSystem.sizePoints}}" min="0" max="99" step="1" style="width:56px;" />
              </div>
              <div class="compact-field"><div class="field-label">Weapon</div><input class="small-input" type="number" name="system.weaponPoints" value="{{mythicVehicleSystem.weaponPoints}}" /></div>
            </div>
          </div>
        </div>

        <div style="margin-top:12px;">
          <h3>Crew & Complement</h3>
          <div class="compact-row" style="margin-bottom:8px;">
            <div class="compact-field"><div class="field-label">Operators</div><input class="small-input" type="number" min="0" step="1" name="system.crew.capacity.operators" value="{{mythicVehicleSystem.crew.capacity.operators}}" /></div>
            <div class="compact-field"><div class="field-label">Gunners</div><input class="small-input" type="number" min="0" step="1" name="system.crew.capacity.gunners" value="{{mythicVehicleSystem.crew.capacity.gunners}}" /></div>
            <div class="compact-field"><div class="field-label">Passengers</div><input class="small-input" type="number" min="0" step="1" name="system.crew.capacity.passengers" value="{{mythicVehicleSystem.crew.capacity.passengers}}" /></div>
          </div>

          <h3>Special Rules</h3>
          <div class="special-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; font-size:12px;">
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.allTerrain.has" value="false" />
              <input id="special-{{actor.id}}-allTerrain-has" type="checkbox" name="system.special.allTerrain.has" value="true" {{#if mythicVehicleSystem.special.allTerrain.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-allTerrain-has">All-Terrain</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.antiGrav.has" value="false" />
              <input id="special-{{actor.id}}-antiGrav-has" type="checkbox" name="system.special.antiGrav.has" value="true" {{#if mythicVehicleSystem.special.antiGrav.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-antiGrav-has">Anti-Gravitational</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.autoloader.has" value="false" />
              <input id="special-{{actor.id}}-autoloader-has" type="checkbox" name="system.special.autoloader.has" value="true" {{#if mythicVehicleSystem.special.autoloader.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-autoloader-has">Autoloader</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.boost.has" value="false" />
              <input id="special-{{actor.id}}-boost-has" type="checkbox" name="system.special.boost.has" value="true" {{#if mythicVehicleSystem.special.boost.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-boost-has">Boost</label>
              <input class="small-input" type="number" name="system.special.boost.value" value="{{mythicVehicleSystem.special.boost.value}}" min="0" max="9" step="1" style="width:30px;margin-left:6px;" />
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.continuousTrack.has" value="false" />
              <input id="special-{{actor.id}}-continuousTrack-has" type="checkbox" name="system.special.continuousTrack.has" value="true" {{#if mythicVehicleSystem.special.continuousTrack.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-continuousTrack-has">Continuous Track</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.enclosedTop.has" value="false" />
              <input id="special-{{actor.id}}-enclosedTop-has" type="checkbox" name="system.special.enclosedTop.has" value="true" {{#if mythicVehicleSystem.special.enclosedTop.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-enclosedTop-has">Enclosed-Top</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.flight.has" value="false" />
              <input id="special-{{actor.id}}-flight-has" type="checkbox" name="system.special.flight.has" value="true" {{#if mythicVehicleSystem.special.flight.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-flight-has">Flight</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.heavyPlating.has" value="false" />
              <input id="special-{{actor.id}}-heavyPlating-has" type="checkbox" name="system.special.heavyPlating.has" value="true" {{#if mythicVehicleSystem.special.heavyPlating.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-heavyPlating-has">Heavy Plating</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.neuralInterface.has" value="false" />
              <input id="special-{{actor.id}}-neuralInterface-has" type="checkbox" name="system.special.neuralInterface.has" value="true" {{#if mythicVehicleSystem.special.neuralInterface.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-neuralInterface-has">Neural Interface</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.openTop.has" value="false" />
              <input id="special-{{actor.id}}-openTop-has" type="checkbox" name="system.special.openTop.has" value="true" {{#if mythicVehicleSystem.special.openTop.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-openTop-has">Open-Top</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.slipspace.has" value="false" />
              <input id="special-{{actor.id}}-slipspace-has" type="checkbox" name="system.special.slipspace.has" value="true" {{#if mythicVehicleSystem.special.slipspace.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-slipspace-has">Slipspace Travel</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.walkerStomp.has" value="false" />
              <input id="special-{{actor.id}}-walkerStomp-has" type="checkbox" name="system.special.walkerStomp.has" value="true" {{#if mythicVehicleSystem.special.walkerStomp.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-walkerStomp-has">Walker Stomp</label>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
{{else}}
<div class="{{cssClass}} mythic-character-sheet" data-faction="{{mythicFactionIndex}}">
  <aside class="sheet-nav">
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item" data-tab="main" title="Main">
        <i class="fas fa-user"></i>
      </a>
      <a class="item" data-tab="skills" title="Skills &amp; Educations">
        <i class="fas fa-list"></i>
      </a>
      <a class="item" data-tab="abilities" title="Abilities">
        <i class="fas fa-bolt"></i>
      </a>
      <a class="item" data-tab="equipment" title="Inventory">
        <i class="fas fa-toolbox"></i>
      </a>
      <a class="item" data-tab="medical" title="Medical">
        <i class="fas fa-heart-pulse"></i>
      </a>
      <a class="item" data-tab="advancements" title="Character Creation and Advancement">
        <i class="fas fa-arrow-trend-up"></i>
      </a>
      <a class="item" data-tab="notes" title="Notes">
        <i class="fas fa-note-sticky"></i>
      </a>
      <a class="item" data-tab="biography" title="Biography">
        <i class="fas fa-book-open"></i>
      </a>
      <a class="item" data-tab="vehicles" title="Vehicles">
        <i class="fas fa-truck"></i>
      </a>
      <a class="item" data-tab="setup" title="Settings">
        <i class="fas fa-gear"></i>
      </a>
    </nav>
  </aside>

  <section class="sheet-content">
    {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/header.hbs"}}
    <div class="sheet-tab-scrollable">
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/main-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/skills-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/abilities-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/equipment-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/medical-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/advancements-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/notes-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/biography-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/vehicles-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/setup-tab.hbs"}}
    </div>
  </section>
</div>
{{/if}}
