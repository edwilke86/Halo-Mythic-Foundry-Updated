<div
  class="mythic-character-sheet mythic-bestiary-shell mythic-sheet-theme-root"
  data-faction="{{mythicFactionIndex}}"
  data-subtype="{{mythicBestiarySubtype}}"
  data-flood-form="{{mythicFloodFormClass}}"
  data-theme-preset="{{mythicSheetAppearance.preset}}"
  data-panel-style="{{mythicSheetAppearance.panelStyle}}"
  data-portrait-frame="{{mythicSheetAppearance.portraitFrame}}"
  data-banner-style="{{mythicSheetAppearance.banner.style}}"
  data-has-banner="{{#if mythicSheetAppearance.displayBanner}}true{{else}}false{{/if}}">
  <aside class="sheet-nav">
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item" data-tab="main" title="Main">
        <i class="fas fa-user"></i>
      </a>
      <a class="item" data-tab="equipment" title="Equipment">
        <i class="fas fa-toolbox"></i>
      </a>
      <a class="item" data-tab="knowledge" title="Skills &amp; Knowledge">
        <i class="fas fa-brain"></i>
      </a>
      <a class="item" data-tab="medical" title="Medical">
        <i class="fas fa-heart-pulse"></i>
      </a>
      <a class="item" data-tab="biography" title="Biography">
        <i class="fas fa-book-open"></i>
      </a>
      <a class="item" data-tab="vehicles" title="Vehicles">
        <i class="fas fa-truck"></i>
      </a>
      <a class="item" data-tab="setup" title="Setup">
        <i class="fas fa-gear"></i>
      </a>
    </nav>
  </aside>

  <section class="sheet-content">
    <header class="mythic-bestiary-header mythic-bestiary-sticky-header mythic-sheet-header-surface">
      <div class="mythic-bestiary-portrait-column">
        <div class="mythic-bestiary-portrait-wrap mythic-sheet-portrait-surface">
          <img class="profile-img mythic-sheet-portrait-image" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}" />
        </div>
        {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/sheet-appearance-banner.hbs"}}
      </div>
      <div class="mythic-bestiary-header-fields">
        <div class="mythic-bestiary-header-title-row">
          <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Bestiary Entry" /></h1>
          <label class="mythic-bestiary-header-xp-field" title="Current XP payout for the selected BR.">
            XP Payout
            <input type="number" min="0" step="1" value="{{mythicCurrentXpPayout}}" readonly />
          </label>
        </div>
        <div class="mythic-bestiary-header-grid">
          <label>
            BR Level
            <select name="system.bestiary.rank">
              {{#each rankOptions as |opt|}}
                <option value="{{opt.value}}"{{#if opt.selected}} selected{{/if}}>{{opt.label}}</option>
              {{/each}}
            </select>
          </label>
          <label>
            Soldier Type
            <input type="text" name="system.header.soldierType" value="{{system.header.soldierType}}" />
          </label>
          <label>
            Race
            <input type="text" name="system.header.race" value="{{system.header.race}}" />
          </label>
          <label>
            Faction
            <input type="text" name="system.header.faction" value="{{system.header.faction}}" />
          </label>
        </div>
      </div>
    </header>

    <div class="sheet-tab-scrollable">
      <div class="tab main" data-group="primary" data-tab="main">
        {{#if mythicPreparedTabs.main}}
        {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/main-tab-characteristics-panel.hbs" }}

        <section class="panel mythic-derived-panel">
          <div class="mythic-derived-4col">

            <details class="mythic-derived-card" data-collapse-key="mythic-card" open>
              <summary>Mythic</summary>
              <div class="mythic-mini-strip">
                <div class="mythic-mini-block">
                  <div class="mythic-mini-label">STR</div>
                  <input type="number" min="0" name="system.mythic.characteristics.str" value="{{mythicDerived.mythicCharacteristics.str}}" disabled title="Derived from base + BR bonuses + misc additive modifiers (Setup tab)." />
                </div>
                <div class="mythic-mini-block">
                  <div class="mythic-mini-label">TOU</div>
                  <input type="number" min="0" name="system.mythic.characteristics.tou" value="{{mythicDerived.mythicCharacteristics.tou}}" disabled title="Derived from base + BR bonuses + misc additive modifiers (Setup tab)." />
                </div>
                <div class="mythic-mini-block">
                  <div class="mythic-mini-label">AGI</div>
                  <input type="number" min="0" name="system.mythic.characteristics.agi" value="{{mythicDerived.mythicCharacteristics.agi}}" disabled title="Derived from base + BR bonuses + misc additive modifiers (Setup tab)." />
                </div>
              </div>
            </details>

            <details class="mythic-derived-card movement-card" data-collapse-key="movement-card" open>
              <summary>{{#if mythicIsHuragok}}Character Movement (ONLY FLIGHT){{else}}Character Movement{{/if}}</summary>
              <div class="movement-strip">
                <div class="movement-block"><div class="movement-value">{{#if mythicIsHuragok}}{{mythicDerived.movement.flyHalf}}{{else}}{{mythicDerived.movement.half}}{{/if}}</div><div class="movement-label movement-label-half">Half</div></div>
                <div class="movement-block"><div class="movement-value">{{#if mythicIsHuragok}}{{mythicDerived.movement.flyFull}}{{else}}{{mythicDerived.movement.full}}{{/if}}</div><div class="movement-label movement-label-full">Full</div></div>
                <div class="movement-block"><div class="movement-value">{{#if mythicIsHuragok}}{{mythicDerived.movement.flyCharge}}{{else}}{{mythicDerived.movement.charge}}{{/if}}</div><div class="movement-label movement-label-charge">Charge</div></div>
                <div class="movement-block"><div class="movement-value">{{#if mythicIsHuragok}}{{mythicDerived.movement.flyRun}}{{else}}{{mythicDerived.movement.run}}{{/if}}</div><div class="movement-label movement-label-run">Run</div></div>
                {{#if mythicHasBlurAbility}}
                  <div class="movement-block"><div class="movement-value">{{#if mythicIsHuragok}}{{mythicDerived.movement.flySprint}}{{else}}{{mythicDerived.movement.sprint}}{{/if}}</div><div class="movement-label movement-label-sprint">Sprint</div></div>
                {{/if}}
                <div class="movement-block"><div class="movement-value">{{#if mythicIsHuragok}}-{{else}}{{mythicDerived.movement.jump}}{{/if}}</div><div class="movement-label">Jump</div></div>
                <div class="movement-block"><div class="movement-value">{{#if mythicIsHuragok}}-{{else}}{{mythicDerived.movement.leap}}{{/if}}</div><div class="movement-label">Leap</div></div>
              </div>
              {{#if mythicDerived.movement.hasFlightTrait}}
              {{#unless mythicIsHuragok}}
              <div class="movement-fly-section">
                <div class="movement-fly-header">Fly Speeds</div>
                {{#if mythicDerived.movement.canFly}}
                <div class="movement-strip">
                  <div class="movement-block"><div class="movement-value">{{mythicDerived.movement.flyHalf}}</div><div class="movement-label movement-label-half">Half</div></div>
                  <div class="movement-block"><div class="movement-value">{{mythicDerived.movement.flyFull}}</div><div class="movement-label movement-label-full">Full</div></div>
                  <div class="movement-block"><div class="movement-value">{{mythicDerived.movement.flyCharge}}</div><div class="movement-label movement-label-charge">Charge</div></div>
                  <div class="movement-block"><div class="movement-value">{{mythicDerived.movement.flyRun}}</div><div class="movement-label movement-label-run">Run</div></div>
                  {{#if mythicHasBlurAbility}}
                    <div class="movement-block"><div class="movement-value">{{mythicDerived.movement.flySprint}}</div><div class="movement-label movement-label-sprint">Sprint</div></div>
                  {{/if}}
                </div>
                {{else}}
                <div class="movement-fly-unavailable">Unable to fly - carrying capacity over 75%</div>
                {{/if}}
                <div class="movement-fly-encumbrance">Carry: {{mythicDerived.movement.carryPercentage}}%</div>
              </div>
              {{/unless}}
              {{/if}}

              <details class="movement-reference" data-collapse-key="movement-reference">
                <summary>Movement Reference</summary>
                <div class="movement-ref-content">
                  <p><strong>Jump Distance:</strong> {{mythicDerived.movement.jump}} m. This is the maximum vertical height your character can jump.</p>
                  <p><strong>Leap Distance:</strong> {{mythicDerived.movement.leap}} m. This is the maximum horizontal distance your character can clear.</p>
                  <p><strong>Climb Speed:</strong> Full Action up to {{mythicDerived.movement.climbNoTest}} m with no test. Up to {{mythicDerived.movement.climbWithTest}} m with a Climb Test.</p>
                  <p><strong>Jump Bonus While Moving:</strong> Add +1 m leap distance for every 10 m moved this turn.</p>
                  <p><strong>Swim Speed:</strong> {{mythicDerived.movement.swimSpeed}} m/turn (STR MOD, no Mythic).</p>
                  <p><strong>Initiative Formula:</strong> 1d10 + AGI MOD + (Mythic AGI / 2) + Manual Bonus + Misc.</p>
                </div>
              </details>
            </details>

            <details class="mythic-derived-card" data-collapse-key="weight-card" open>
              <summary>Weight</summary>
              <div class="movement-strip">
                <div class="movement-block"><div class="movement-value">{{mythicDerived.carryingCapacity.carry}}</div><div class="movement-label">Carry</div></div>
                <div class="movement-block"><div class="movement-value">{{mythicDerived.carryingCapacity.lift}}</div><div class="movement-label">Lift</div></div>
                <div class="movement-block"><div class="movement-value">{{mythicDerived.carryingCapacity.push}}</div><div class="movement-label">Push</div></div>
              </div>
              <details class="movement-reference" data-collapse-key="weight-reference">
                <summary>Gravity</summary>
                <div class="movement-ref-content">
                  <div class="movement-ref-row gravity-input-row">
                    <label>Current Gravity</label>
                    <input type="number" name="system.gravity" min="0" max="4" step="0.1" value="{{mythicGravityValue}}" readonly />
                    {{#if mythicIsGM}}<span class="mythic-gravity-gm-hint">Set in <strong>Game Settings</strong></span>{{/if}}
                  </div>
                </div>
              </details>
            </details>
          </div>
        </section>

        <section class="panel mythic-combat-panel">
          <div class="mythic-combat-section-header">
            <h2>Combat Resources</h2>
            <div class="mythic-initiative-control">
              <span class="mythic-initiative-label">Init:</span>
              <button type="button" class="action-btn mythic-initiative-roll-btn" title="Roll Initiative: 1d10 + AGI Mod + (Mythic AGI / 2) + Manual Bonus + Misc.">
                <i class="fa-solid fa-dice-d10"></i>
              </button>
              <button type="button" class="action-btn fear-test-btn" title="Run a Fear Test flow (Courage -> Shock -> PTSD).">Fear Test</button>
            </div>
          </div>
          <div class="mythic-combat-grid">
            <div class="mythic-combat-column left">
              <div class="mythic-resource-line">
                <div class="mythic-resource-label">Wounds</div>
                <div class="mythic-resource-values">
                  <div class="mythic-mini-field"><span>Current</span><input type="number" min="0" name="system.combat.wounds.current" value="{{mythicCombat.wounds.current}}" /></div>
                  <div class="mythic-mini-field"><span>Max</span><input type="number" min="0" name="system.combat.wounds.max" value="{{mythicCombat.wounds.max}}" readonly /></div>
                </div>
                <div class="mythic-resource-actions">
                  <button type="button" class="action-btn wounds-full-heal-btn">Full Heal</button>
                </div>
              </div>

              <div class="mythic-resource-line">
                <div class="mythic-resource-label">Fatigue</div>
                <div class="mythic-resource-values">
                  <div class="mythic-mini-field"><span>Current</span><input type="number" min="0" name="system.combat.fatigue.current" value="{{mythicCombat.fatigue.current}}" /></div>
                  <div class="mythic-mini-field"><span>Max</span><input type="number" min="0" name="system.combat.fatigue.max" value="{{mythicCombat.fatigue.max}}" readonly /></div>
                </div>
              </div>

              <div class="mythic-resource-line">
                <div class="mythic-resource-label">Luck</div>
                <div class="mythic-resource-values">
                  <div class="mythic-mini-field"><span>Current</span><input type="number" min="0" name="system.combat.luck.current" value="{{mythicCombat.luck.current}}" /></div>
                  <div class="mythic-mini-field"><span>Max</span><input type="number" min="0" name="system.combat.luck.max" value="{{mythicCombat.luck.max}}" /></div>
                </div>
              </div>
            </div>

            <div class="mythic-combat-column center">
              <div class="mythic-dr-headings">
                <div></div>
                <div class="mythic-dr-column-label">DR</div>
                <div class="mythic-dr-column-label">Armor Only</div>
              </div>
              <div class="mythic-dr-row"><div class="mythic-dr-label">Head</div><div class="mythic-dr-value">{{mythicCombat.dr.head.total}}</div><input type="number" min="0" name="system.combat.dr.armor.head" value="{{mythicCombat.dr.head.armor}}" readonly /></div>
              <div class="mythic-dr-row"><div class="mythic-dr-label">Chest</div><div class="mythic-dr-value">{{mythicCombat.dr.chest.total}}</div><input type="number" min="0" name="system.combat.dr.armor.chest" value="{{mythicCombat.dr.chest.armor}}" readonly /></div>
              <div class="mythic-dr-row"><div class="mythic-dr-label">L Arm</div><div class="mythic-dr-value">{{mythicCombat.dr.lArm.total}}</div><input type="number" min="0" name="system.combat.dr.armor.lArm" value="{{mythicCombat.dr.lArm.armor}}" readonly /></div>
              <div class="mythic-dr-row"><div class="mythic-dr-label">R Arm</div><div class="mythic-dr-value">{{mythicCombat.dr.rArm.total}}</div><input type="number" min="0" name="system.combat.dr.armor.rArm" value="{{mythicCombat.dr.rArm.armor}}" readonly /></div>
              <div class="mythic-dr-row"><div class="mythic-dr-label">L Leg</div><div class="mythic-dr-value">{{mythicCombat.dr.lLeg.total}}</div><input type="number" min="0" name="system.combat.dr.armor.lLeg" value="{{mythicCombat.dr.lLeg.armor}}" readonly /></div>
              <div class="mythic-dr-row"><div class="mythic-dr-label">R Leg</div><div class="mythic-dr-value">{{mythicCombat.dr.rLeg.total}}</div><input type="number" min="0" name="system.combat.dr.armor.rLeg" value="{{mythicCombat.dr.rLeg.armor}}" readonly /></div>
              <div class="mythic-dr-row tou-row"><div class="mythic-dr-label">Base</div><div class="mythic-dr-value">{{mythicCombat.dr.touCombined}}</div><div class="mythic-dr-note">--</div></div>
              {{#if mythicDerived.naturalArmor.enabled}}
              <div class="mythic-dr-row mythic-dr-nat-armor-row">
                <div class="mythic-dr-label">Nat.</div>
                <div class="mythic-dr-value">+{{mythicCombat.dr.naturalArmorBody}}</div>
                <div class="mythic-dr-note">Natural Armor{{#if mythicDerived.naturalArmor.isWearingArmor}} (halved){{/if}}</div>
              </div>
              {{/if}}
            </div>

            <div class="mythic-combat-column right">
              <div class="mythic-right-block">
                <div class="mythic-resource-label">Shields</div>
                <div class="mythic-shield-grid">
                  <div class="mythic-mini-field"><span>Current Integrity</span><input type="number" min="0" name="system.combat.shields.current" value="{{mythicCombat.shields.current}}" /></div>
                  <div class="mythic-mini-field"><span>Max Integrity</span><input type="number" min="0" name="system.combat.shields.integrity" value="{{mythicCombat.shields.integrity}}" readonly /></div>
                  <div class="mythic-mini-field"><span>Recharge Delay</span><input type="number" min="0" name="system.combat.shields.rechargeDelay" value="{{mythicCombat.shields.rechargeDelay}}" readonly /></div>
                  <div class="mythic-mini-field"><button type="button" class="shields-recharge-btn mythic-mini-action-label">Recharge</button><input type="number" min="0" name="system.combat.shields.rechargeRate" value="{{mythicCombat.shields.rechargeRate}}" readonly /></div>
                </div>
              </div>

              <div class="mythic-right-block">
                <div class="mythic-resource-label">Support Points</div>
                <div class="mythic-resource-values">
                  <div class="mythic-mini-field"><span>Current</span><input type="number" min="0" name="system.combat.supportPoints.current" value="{{mythicCombat.supportPoints.current}}" /></div>
                  <div class="mythic-mini-field"><span>Max</span><input type="number" min="0" name="system.combat.supportPoints.max" value="{{mythicCombat.supportPoints.max}}" /></div>
                </div>
              </div>

              <div class="mythic-right-block">
                <div class="mythic-resource-label">Turn Economy</div>
                <div class="mythic-reactions-tracker mythic-action-economy-tracker">
                  <div class="mythic-turn-economy-row">
                    <span>Reactions: <strong class="mythic-turn-economy-symbols">{{mythicCombat.reactions.symbols}}</strong></span>
                    <span>Half Actions: <strong>{{mythicCombat.actionEconomy.compactLabel}}</strong></span>
                  </div>
                  <div class="mythic-turn-economy-row">
                    <span>Penalty: <strong>{{mythicCombat.reactions.penaltyLabel}}</strong></span>
                    <span>Status: <strong>{{mythicCombat.actionEconomy.statusText}}</strong></span>
                  </div>
                  {{#if mythicCombat.actionEconomy.hasHistory}}
                    <div class="mythic-action-economy-history">
                      {{#each mythicCombat.actionEconomy.history}}<div>{{label}} ({{halfActions}} HA)</div>{{/each}}
                    </div>
                  {{/if}}
                  <div class="mythic-reaction-controls">
                    <button type="button" class="action-btn reaction-add-btn">+ Reaction</button>
                    <button type="button" class="action-btn action-economy-advance-half-btn" title="Advance one Half Action.">+HA</button>
                    <button type="button" class="action-btn turn-economy-reset-btn">Reset Turn</button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="mythic-ready-weapons-section">
            <h3>Readied Weapons <span class="mythic-drop-hint">(drop a weapon item to add)</span></h3>
            {{#if mythicEquipment.readyWeaponCards.length}}
              <div class="mythic-ready-weapon-grid">
                {{#each mythicEquipment.readyWeaponCards as |weapon|}}
                <article class="mythic-ready-weapon-card">
                  <header class="mythic-ready-weapon-card-header">
                    <div>
                      {{#if weapon.hasTrainingWarning}}
                      <div class="mythic-ready-weapon-warning" title="{{weapon.trainingWarningText}}">{{weapon.trainingWarningText}}</div>
                      {{/if}}
                      <div class="mythic-ready-weapon-name-row">
                        <div class="mythic-ready-weapon-name">{{weapon.name}}</div>
                        <button type="button" class="action-btn gear-open-btn mythic-ready-weapon-edit-btn" data-item-id="{{weapon.id}}" title="Edit item" aria-label="Edit item"><i class="fas fa-pen-to-square"></i></button>
                      </div>
                      {{#if weapon.nickname}}<div class="mythic-ready-weapon-nickname">"{{weapon.nickname}}"</div>{{/if}}
                      <div class="mythic-ready-weapon-meta">
                        {{weapon.displayWeaponClass}}
                      </div>
                    </div>
                    <div class="mythic-ready-weapon-header-actions">
                      <span class="mythic-ready-weapon-state">Ready</span>
                      <button type="button" class="action-btn mythic-bestiary-remove-weapon-btn" data-bestiary-remove-item="{{weapon.id}}" title="Remove weapon"><i class="fas fa-times"></i></button>
                    </div>
                  </header>

                  {{#if weapon.showStandardFireModes}}
                  <div class="mythic-ready-weapon-modes">
                    {{#each weapon.fireModes as |mode|}}
                    <button type="button" class="action-btn weapon-fire-mode-btn {{#if mode.isSelected}}is-active{{/if}}" data-item-id="{{weapon.id}}" data-fire-mode="{{mode.value}}">{{mode.label}}</button>
                    {{/each}}
                  </div>
                  {{/if}}

                  {{#if weapon.showVariantSelector}}
                  <div class="mythic-ready-weapon-modes mythic-variant-selector" aria-label="Attack variant">
                    {{#each weapon.variantOptions as |opt|}}
                    <button type="button" class="action-btn weapon-variant-btn {{#if opt.isSelected}}is-active{{/if}}" data-item-id="{{weapon.id}}" data-variant-index="{{opt.index}}" aria-pressed="{{#if opt.isSelected}}true{{else}}false{{/if}}" title="Switch to {{opt.label}}">{{opt.label}}</button>
                    {{/each}}
                  </div>
                  {{/if}}

                  <div class="mythic-ready-weapon-attacks">
                    {{#if weapon.hasChargeModeSelected}}
                      <button type="button" class="action-btn weapon-attack-btn weapon-charge-fire-btn" data-item-id="{{weapon.id}}" data-action="chargeFire">Fire</button>
                    {{else}}
                    {{#if weapon.showSustainedAttack}}<button type="button" class="action-btn weapon-attack-btn" data-item-id="{{weapon.id}}" data-action="single">Attack</button>{{/if}}
                    {{#if weapon.showSingleAttack}}<button type="button" class="action-btn weapon-attack-btn" data-item-id="{{weapon.id}}" data-action="single">Single Attack</button>{{/if}}
                    {{#if weapon.showHalfAttack}}<button type="button" class="action-btn weapon-attack-btn" data-item-id="{{weapon.id}}" data-action="half">Half Action ({{weapon.halfActionAttackCount}})</button>{{/if}}
                    {{#if weapon.showFullAttack}}<button type="button" class="action-btn weapon-attack-btn" data-item-id="{{weapon.id}}" data-action="full">Full Action ({{weapon.fullActionAttackCount}})</button>{{/if}}
                    {{#if weapon.showExecutionAttack}}<button type="button" class="action-btn weapon-attack-btn weapon-execution-btn" data-item-id="{{weapon.id}}" data-action="execution" aria-label="Execution Attack">&#9760;</button>{{/if}}
                    {{#if weapon.showButtstrokeAttack}}<button type="button" class="action-btn weapon-attack-btn weapon-buttstroke-btn" data-item-id="{{weapon.id}}" data-action="buttstroke" aria-label="Buttstroke">Butt</button>{{/if}}
                    {{#if weapon.showPumpReactionAttack}}<button type="button" class="action-btn weapon-attack-btn" data-item-id="{{weapon.id}}" data-action="pump-reaction">Reaction Shot</button>{{/if}}
                    {{/if}}
                  </div>

                  {{#if weapon.hasChargeModeSelected}}
                  <div class="mythic-ready-weapon-charge-row">
                    <div class="mythic-charge-meter" title="Charge Level">
                      {{#each weapon.chargePips as |pip|}}
                      <span class="mythic-charge-pip {{#if pip.filled}}is-filled{{/if}}" aria-hidden="true"></span>
                      {{/each}}
                    </div>
                    <div class="mythic-charge-label">Charge {{weapon.chargeLevel}}/{{weapon.chargeMaxLevel}} (+{{weapon.chargeDamageBonusPreview}} dmg)</div>
                    <button type="button" class="action-btn weapon-charge-btn" data-item-id="{{weapon.id}}">Charge</button>
                    <button type="button" class="action-btn weapon-clear-charge-btn" data-item-id="{{weapon.id}}">Clear</button>
                  </div>
                  {{/if}}

                  {{#if weapon.isMelee}}
                  <div class="mythic-ready-weapon-row-inline">
                    <span><strong>Reach:</strong> {{weapon.reach}} m</span>
                    <span><strong>Damage:</strong> {{weapon.damageDiceLabel}} + {{weapon.displayDamageBase}}</span>
                    <span><strong>Pierce:</strong> {{weapon.displayDamagePierce}}</span>
                    {{#if weapon.currentAttackName}}<span class="mythic-attack-type-badge">{{weapon.currentAttackName}}</span>{{/if}}
                  </div>
                  {{else}}
                    {{#if weapon.isEnergyWeapon}}
                    <div class="mythic-ready-weapon-row-inline mythic-energy-weapon-row">
                      <div class="mythic-energy-meter-wrap" title="{{weapon.energyCellCurrent}} / {{weapon.energyCellCapacity}}">
                        <span class="mythic-energy-meter-label"><strong>Battery:</strong></span>
                        <div class="mythic-energy-meter" role="meter" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{weapon.energyCellPercent}}">
                          <div class="mythic-energy-meter-fill" style="width: {{weapon.energyCellPercent}}%;"></div>
                          <span class="mythic-energy-meter-text">{{weapon.energyCellPercentDisplay}}%</span>
                        </div>
                      </div>
                      <label>Batteries &mdash; TOTAL
                        <input type="number" min="0" class="weapon-state-input" data-item-id="{{weapon.id}}" data-field="ammoTotal" value="{{weapon.ammoTotal}}" />
                      </label>
                      <button type="button" class="action-btn weapon-reload-btn" data-item-id="{{weapon.id}}">Reload</button>
                      <span><strong>Range:</strong> {{weapon.rangeClose}} / {{weapon.rangeMax}} m</span>
                    </div>
                    {{else}}
                    <div class="mythic-ready-weapon-row-inline">
                      <label>Ammo &mdash; TOTAL
                        <input type="number" min="0" class="weapon-state-input" data-item-id="{{weapon.id}}" data-field="ammoTotal" value="{{weapon.ammoTotal}}" />
                      </label>
                      <span><strong>{{weapon.ammoLoadLabel}}:</strong> {{weapon.magazineCurrent}} / {{weapon.magazineMax}}</span>
                      <button type="button" class="action-btn weapon-reload-btn" data-item-id="{{weapon.id}}">Reload</button>
                      <span><strong>Range:</strong> {{weapon.rangeClose}} / {{weapon.rangeMax}} m</span>
                    </div>
                    {{/if}}
                  {{/if}}

                  {{#if weapon.hasReadyBadges}}
                  <div class="mythic-ready-weapon-badges" aria-label="Weapon tags and special rules">
                    {{#each weapon.readyBadges as |badge|}}
                    <span class="mythic-ready-weapon-badge {{#if (eq badge.kind "rule")}}is-rule{{else}}is-tag{{/if}}" title="{{badge.fullLabel}}">{{badge.shortLabel}}</span>
                    {{/each}}
                  </div>
                  {{/if}}

                  <div class="mythic-ready-weapon-controls">
                    {{#unless weapon.isMelee}}
                    <label>Scope
                      <select class="weapon-state-input" data-item-id="{{weapon.id}}" data-field="scopeMode">
                        {{selectOptions weapon.scopeOptions selected=weapon.scopeMode}}
                      </select>
                    </label>
                    {{/unless}}
                    <label>To Hit Mod
                      <input type="number" step="1" class="weapon-state-input" data-item-id="{{weapon.id}}" data-field="toHitModifier" value="{{weapon.toHitModifier}}" />
                    </label>
                    <label>Damage Mod
                      <input type="number" step="1" class="weapon-state-input" data-item-id="{{weapon.id}}" data-field="damageModifier" value="{{weapon.damageModifier}}" />
                    </label>
                  </div>

                  {{#unless weapon.isMelee}}
                  <div class="mythic-ready-weapon-row-inline">
                    <span><strong>Reload:</strong> {{weapon.rangeReload}}</span>
                    <span><strong>{{weapon.ammoCapacityLabel}}:</strong> {{weapon.magazineMax}}</span>
                  </div>
                  {{/unless}}
                </article>
                {{/each}}
              </div>
            {{else}}
              <p class="mythic-ready-weapon-empty">No readied weapons. Drop a weapon item here.</p>
            {{/if}}
          </div>
        </section>
        {{/if}}
      </div>

      <div class="tab equipment" data-group="primary" data-tab="equipment">
        {{#if mythicPreparedTabs.equipment}}
        <section class="mythic-bestiary-sheet">
          <section class="mythic-bestiary-panel">
            <div class="mythic-bestiary-section-head">
              <h2>Equipment List</h2>
              <button type="button" data-action="add-equipment">Add Row</button>
            </div>
            {{#if equipmentList.length}}
              <div class="mythic-bestiary-equipment-list">
                {{#each equipmentList as |entry index|}}
                  <div class="mythic-bestiary-equipment-row">
                    <input type="text" placeholder="Item name" name="system.bestiary.equipmentList.{{index}}.name" value="{{entry.name}}" />
                    <input type="number" min="0" step="1" name="system.bestiary.equipmentList.{{index}}.quantity" value="{{entry.quantity}}" />
                    <button type="button" class="mythic-bestiary-embedded-remove" data-remove-equipment-id="{{entry.id}}">✕</button>
                    <input type="hidden" name="system.bestiary.equipmentList.{{index}}.id" value="{{entry.id}}" />
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="mythic-empty-state">No equipment rows yet.</p>
            {{/if}}
          </section>

          <section class="mythic-bestiary-panel">
            <h2>Weapons</h2>
            {{#if mythicEquipment.readyWeaponCards.length}}
              {{#each mythicEquipment.readyWeaponCards as |weapon|}}
                <div class="mythic-bestiary-equipped-armor-row">
                  <img class="mythic-bestiary-embedded-img" src="{{weapon.img}}" alt="{{weapon.name}}" />
                  <div class="mythic-bestiary-embedded-info">
                    <span class="mythic-bestiary-embedded-name">{{weapon.name}}</span>
                    <span class="mythic-bestiary-embedded-tag">{{#if weapon.isMelee}}Melee{{else}}Ranged{{/if}}</span>
                  </div>
                  <button type="button" class="mythic-bestiary-embedded-remove" data-bestiary-remove-weapon="{{weapon.id}}" title="Remove weapon">✕</button>
                </div>
              {{/each}}
            {{else}}
              <p class="mythic-empty-state">No weapons. Drop a weapon item here.</p>
            {{/if}}
          </section>

          {{#if bestiaryEquippedArmor}}
            <section class="mythic-bestiary-panel">
              <h2>Equipped Armor</h2>
              <div class="mythic-bestiary-equipped-armor-row">
                <img class="mythic-bestiary-embedded-img" src="{{bestiaryEquippedArmor.img}}" alt="{{bestiaryEquippedArmor.name}}" />
                <div class="mythic-bestiary-embedded-info">
                  <span class="mythic-bestiary-embedded-name">{{bestiaryEquippedArmor.name}}</span>
                  {{#if bestiaryEquippedArmor.isFloodHalved}}<span class="mythic-bestiary-embedded-tag">Flood (halved)</span>{{/if}}
                  <span class="mythic-bestiary-embedded-desc">Head {{bestiaryEquippedArmor.head}} | Chest {{bestiaryEquippedArmor.chest}} | Arms {{bestiaryEquippedArmor.arms}} | Legs {{bestiaryEquippedArmor.legs}}</span>
                  {{#if bestiaryEquippedArmor.shieldIntegrity}}<span class="mythic-bestiary-embedded-desc">Shield {{bestiaryEquippedArmor.shieldIntegrity}} | Delay {{bestiaryEquippedArmor.rechargeDelay}} | Rate {{bestiaryEquippedArmor.rechargeRate}}</span>{{/if}}
                </div>
                <button type="button" class="mythic-bestiary-embedded-remove" data-bestiary-unequip-armor="{{bestiaryEquippedArmor.id}}" title="Unequip armor">✕</button>
              </div>
            </section>
          {{else}}
            <section class="mythic-bestiary-panel">
              <h2>Equipped Armor</h2>
              <p class="mythic-empty-state">No armor equipped. Drop an armor item here.</p>
            </section>
          {{/if}}
        </section>
        {{/if}}
      </div>

      <div class="tab knowledge" data-group="primary" data-tab="knowledge">
        {{#if mythicPreparedTabs.knowledge}}
        <section class="mythic-bestiary-sheet">
          {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/skills-tab.hbs" }}

          <section class="mythic-bestiary-panel" style="margin-top:12px;">
            <h2>Abilities <span class="mythic-drop-hint">(drop an ability to add)</span></h2>
            {{#if mythicAbilities.length}}
            <div class="mythic-abilities-table">
              <div class="mythic-ability-col-headers">
                <div>Name</div>
                <div>Cost</div>
                <div>Action</div>
                <div>Activation</div>
                <div>Description</div>
                <div></div>
              </div>
              {{#each mythicAbilities as |ability|}}
                <div class="mythic-ability-row">
                  <div class="ability-col-name">
                    <div class="ability-name-actions">
                      <button class="ability-open-btn action-btn" type="button" data-item-id="{{ability.id}}" title="Open ability sheet">{{ability.name}}</button>
                    </div>
                  </div>
                  <div class="ability-col-cost">{{ability.cost}}</div>
                  <div class="ability-col-action">{{ability.actionTypeLabel}}</div>
                  <div class="ability-col-activation">
                    {{#if ability.isActivatable}}
                      <button class="ability-activate-btn action-btn" type="button" data-item-id="{{ability.id}}" {{#unless ability.canActivate}}disabled{{/unless}}>Activate</button>
                      <button class="ability-cooldown-btn action-btn" type="button" data-item-id="{{ability.id}}" {{#unless ability.cooldownRemaining}}disabled{{/unless}}>Tick CD</button>
                      <div class="ability-activation-status">Uses {{ability.usesSpent}}{{#if ability.usesMax}}/{{ability.usesMax}}{{else}}/∞{{/if}} | CD {{ability.cooldownRemaining}}</div>
                    {{else}}
                      <div class="ability-activation-status">Passive</div>
                    {{/if}}
                  </div>
                  <div class="ability-col-description" title="{{ability.shortDescription}}">{{ability.shortDescription}}</div>
                  <div class="ability-col-delete">
                    <button class="ability-remove-btn action-btn" type="button" data-item-id="{{ability.id}}" title="Remove ability"><i class="fas fa-times"></i></button>
                  </div>
                </div>
              {{/each}}
            </div>
            {{else}}
              <p class="ability-empty-hint">No abilities yet — drop an ability item to add one.</p>
            {{/if}}
          </section>

          <section class="mythic-bestiary-panel" style="margin-top:12px;">
            <h2>Traits <span class="mythic-drop-hint">(drop a trait to add)</span></h2>
            {{#if mythicTraits.length}}
            <div class="mythic-traits-table">
              <div class="mythic-trait-col-headers">
                <div>Name</div>
                <div>Category</div>
                <div>Access</div>
                <div>Description</div>
                <div></div>
              </div>
              {{#each mythicTraits as |trait|}}
                <div class="mythic-trait-row">
                  <div class="ability-col-name">
                    <button class="trait-open-btn action-btn" type="button" data-item-id="{{trait.id}}" title="Open trait sheet">{{trait.name}}</button>
                  </div>
                  <div class="ability-col-action">{{trait.category}}</div>
                  <div class="ability-col-action">{{#if trait.grantOnly}}Granted{{else}}Selectable{{/if}}</div>
                  <div class="ability-col-description" title="{{trait.shortDescription}}">{{trait.shortDescription}}</div>
                  <div class="ability-col-delete">
                    <button class="trait-remove-btn action-btn" type="button" data-item-id="{{trait.id}}" title="Remove trait"><i class="fas fa-times"></i></button>
                  </div>
                </div>
              {{/each}}
            </div>
            {{else}}
              <p class="ability-empty-hint">No traits yet.</p>
            {{/if}}
          </section>

          <section class="mythic-bestiary-panel" style="margin-top:12px;">
            <h2>Educations <span class="mythic-drop-hint">(drop an education to add)</span></h2>
            {{#if mythicEducations.length}}
            <div class="mythic-abilities-table">
              <div class="mythic-ability-col-headers">
                <div>Name</div>
                <div>Difficulty</div>
                <div>Characteristic</div>
                <div>Skills</div>
                <div></div>
              </div>
              {{#each mythicEducations as |edu|}}
                <div class="mythic-ability-row">
                  <div class="ability-col-name">
                    <button class="education-open-btn action-btn" type="button" data-item-id="{{edu.id}}" title="Open education sheet">{{edu.name}}</button>
                  </div>
                  <div class="ability-col-action">{{edu.difficultyLabel}}</div>
                  <div class="ability-col-action">{{edu.characteristic}}</div>
                  <div class="ability-col-description">{{edu.skills}}</div>
                  <div class="ability-col-delete">
                    <button class="mythic-bestiary-embedded-remove action-btn" type="button" data-bestiary-remove-item="{{edu.id}}" title="Remove education"><i class="fas fa-times"></i></button>
                  </div>
                </div>
              {{/each}}
            </div>
            {{else}}
              <p class="ability-empty-hint">No educations yet.</p>
            {{/if}}
          </section>
        </section>
        {{/if}}
      </div>

      {{#if mythicPreparedTabs.medical}}
        {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/medical-tab.hbs" }}
      {{else}}
        <div class="tab medical" data-group="primary" data-tab="medical"></div>
      {{/if}}

      <div class="tab biography" data-group="primary" data-tab="biography">
        {{#if mythicPreparedTabs.biography}}
        <section class="mythic-bestiary-sheet">
          <section class="mythic-bestiary-panel">
            <div class="mythic-bestiary-section-head">
              <h2>Notes</h2>
              <div class="ccadv-wip-notice"><strong>WIP:</strong> Markdown support coming</div>
              <button type="button" class="action-btn mythic-bestiary-notes-add-btn">Add Note</button>
            </div>
            <div class="mythic-bestiary-notes-grid">
              {{#if mythicBestiaryNotes.length}}
                {{#each mythicBestiaryNotes as |note index|}}
                  <article class="mythic-bestiary-note-card" data-note-id="{{note.id}}" data-note-index="{{index}}">
                    <div class="bestiary-note-card-header">
                      <div class="bestiary-note-actions">
                        <button type="button" class="action-btn mythic-bestiary-note-edit-btn" title="Edit note">Edit</button>
                        <button type="button" class="action-btn mythic-bestiary-note-save-btn" title="Save note">Save</button>
                        <button type="button" class="action-btn mythic-bestiary-note-delete-btn" title="Delete note">Delete</button>
                      </div>
                    </div>
                    <div class="bestiary-note-editor">
                      <textarea class="bestiary-note-description-input" rows="10" placeholder="Note (Markdown)">{{note.description}}</textarea>
                    </div>
                    <div class="bestiary-note-preview" data-description="{{note.description}}">{{{note.descriptionHtml}}}</div>
                  </article>
                {{/each}}
              {{else}}
                <p class="mythic-empty-state">No notes yet. Click Add Note to create one.</p>
              {{/if}}
            </div>
          </section>
        </section>
        {{/if}}
      </div>

      {{#if mythicPreparedTabs.vehicles}}
        {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/vehicles-tab.hbs"}}
      {{else}}
        <div class="tab vehicles mythic-character-vehicle-tab mythic-vehicle-fallback-sheet" data-group="primary" data-tab="vehicles"></div>
      {{/if}}

      <div class="tab setup" data-group="primary" data-tab="setup">
        {{#if mythicPreparedTabs.setup}}
        <section class="mythic-bestiary-sheet">
          <section class="mythic-bestiary-panel">
            <h2>Bestiary Classification</h2>
            <div class="mythic-bestiary-grid-4">
              <label>
                Subtype
                <select name="system.bestiary.subtype">
                  {{#each bestiarySubtypeOptions as |option|}}
                    <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                  {{/each}}
                </select>
              </label>
            </div>
          </section>

          {{#if mythicIsFloodBestiary}}
            <section class="mythic-bestiary-panel mythic-flood-setup-panel">
              <h2>Flood Campaign State</h2>
              <div class="mythic-bestiary-grid-4">
                <label>
                  Form Class
                  <input type="text" name="system.bestiary.flood.formClass" value="{{mythicFloodFormClass}}" />
                </label>
                <label>
                  Keymind Role
                  <input type="text" name="system.bestiary.flood.keymindRole" value="{{mythicFloodKeymindRole}}" />
                </label>
                <label>
                  Contamination Level
                  <input type="number" value="{{mythicFloodCampaign.contaminationLevel}}" disabled />
                </label>
              </div>
              <div class="mythic-flood-state-row">
                <span>Juggernaut: {{#if mythicFloodCampaign.juggernautActive}}Active{{else}}Inactive{{/if}}</span>
                <span>Abomination: {{#if mythicFloodCampaign.abominationActive}}Active{{else}}Inactive{{/if}}</span>
                <span>Proto-Gravemind: {{#if mythicFloodCampaign.protoGravemindActive}}Active{{else}}Inactive{{/if}}</span>
                <span>Gravemind: {{#if mythicFloodCampaign.gravemindActive}}Active{{else}}Inactive{{/if}}</span>
              </div>
              <p class="mythic-flood-state-help">Current control intellect baseline for coordinated Flood behavior: <strong>{{mythicFloodCampaign.controlInt}}</strong>.</p>
            </section>
          {{/if}}

          <section class="mythic-bestiary-panel">
            <h2>Characteristics</h2>
            <div class="mythic-bestiary-controls-row">
              <label>
                <input type="checkbox" name="system.bestiary.singleDifficulty" {{#if system.bestiary.singleDifficulty}}checked{{/if}} />
                Single Difficulty
              </label>
            </div>
            <table class="mythic-bestiary-stat-table">
              <thead>
                <tr>
                  <th>Source</th>
                  {{#each characteristicColumns as |col|}}
                    <th>{{col.label}}</th>
                  {{/each}}
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>BR1 Characteristics</td>
                  {{#each characteristicColumns as |col index|}}
                    <td><input type="number" step="1" name="system.bestiary.baseCharacteristics.{{col.key}}" value="{{lookup ../characteristicBaseValues index}}" /></td>
                  {{/each}}
                </tr>
                <tr>
                  <td>BR Modifier</td>
                  {{#each characteristicBrValues as |value|}}
                    <td><input type="number" value="{{value}}" disabled /></td>
                  {{/each}}
                </tr>
                <tr>
                  <td>Misc</td>
                  {{#each characteristicColumns as |col index|}}
                    <td><input type="number" step="1" name="system.bestiary.miscCharacteristics.{{col.key}}" value="{{lookup ../characteristicMiscValues index}}" /></td>
                  {{/each}}
                </tr>
                <tr>
                  <td>Total</td>
                  {{#each characteristicTotalValues as |value|}}
                    <td><input type="number" value="{{value}}" disabled /></td>
                  {{/each}}
                </tr>
              </tbody>
            </table>
          </section>

          <div class="mythic-bestiary-panel-row mythic-bestiary-panel-row-flex">
            <section class="mythic-bestiary-panel mythic-bestiary-mythic-panel">
              <h2>Mythic Characteristics</h2>
              <div class="mythic-bestiary-controls-row">
                <label>
                  <input type="checkbox" name="system.bestiary.advanceMythicStats" {{#if system.bestiary.advanceMythicStats}}checked{{/if}} />
                  Advance Mythic Stats
                </label>
              </div>
              <table class="mythic-bestiary-stat-table mythic-bestiary-mythic-table">
                <thead>
                  <tr>
                    <th>Source</th>
                    {{#each mythicColumns as |col|}}
                      <th>{{col.label}}</th>
                    {{/each}}
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Base</td>
                    {{#each mythicColumns as |col index|}}
                      <td><input type="number" step="1" name="system.bestiary.mythicBase.{{col.key}}" value="{{lookup ../mythicBaseValues index}}" /></td>
                    {{/each}}
                  </tr>
                  <tr>
                    <td>BR Modifier</td>
                    {{#each mythicBrValues as |value|}}
                      <td><input type="number" value="{{value}}" disabled /></td>
                    {{/each}}
                  </tr>
                  <tr>
                    <td>Misc (Additive)</td>
                    {{#each mythicColumns as |col index|}}
                      <td><input type="number" step="1" name="system.bestiary.mythicMisc.{{col.key}}" value="{{lookup ../mythicMiscValues index}}" /></td>
                    {{/each}}
                  </tr>
                  <tr>
                    <td>Total</td>
                    {{#each mythicTotalValues as |value|}}
                      <td><input type="number" value="{{value}}" disabled /></td>
                    {{/each}}
                  </tr>
                </tbody>
              </table>
            </section>

            <section class="mythic-bestiary-panel mythic-bestiary-xp-wounds-panel">
              <h2>XP, Wounds, & Luck By BR <span class="mythic-info-indicator" title="You may modify Luck by BR values if needed, but this is not recommended.">(i)</span></h2>
              <table class="mythic-bestiary-xp-wounds-table">
                <thead>
                  <tr>
                    <th></th>
                    <th>BR1</th>
                    <th>BR2</th>
                    <th>BR3</th>
                    <th>BR4</th>
                    <th>BR5</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>XP</td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.xpPayouts.br1" value="{{system.bestiary.xpPayouts.br1}}" /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.xpPayouts.br2" value="{{system.bestiary.xpPayouts.br2}}" /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.xpPayouts.br3" value="{{system.bestiary.xpPayouts.br3}}" /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.xpPayouts.br4" value="{{system.bestiary.xpPayouts.br4}}" /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.xpPayouts.br5" value="{{system.bestiary.xpPayouts.br5}}" /></td>
                  </tr>
                  <tr>
                    <td>Wounds</td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.woundsByRank.br1" value="{{system.bestiary.woundsByRank.br1}}" /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.woundsByRank.br2" value="{{system.bestiary.woundsByRank.br2}}" /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.woundsByRank.br3" value="{{system.bestiary.woundsByRank.br3}}" /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.woundsByRank.br4" value="{{system.bestiary.woundsByRank.br4}}" /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.woundsByRank.br5" value="{{system.bestiary.woundsByRank.br5}}" /></td>
                  </tr>
                  <tr>
                    <td>Luck</td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.luckByRank.br1" value="{{system.bestiary.luckByRank.br1}}" {{#if mythicIsFloodBestiary}}disabled{{/if}} /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.luckByRank.br2" value="{{system.bestiary.luckByRank.br2}}" {{#if mythicIsFloodBestiary}}disabled{{/if}} /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.luckByRank.br3" value="{{system.bestiary.luckByRank.br3}}" {{#if mythicIsFloodBestiary}}disabled{{/if}} /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.luckByRank.br4" value="{{system.bestiary.luckByRank.br4}}" {{#if mythicIsFloodBestiary}}disabled{{/if}} /></td>
                    <td><input type="number" min="0" step="1" name="system.bestiary.luckByRank.br5" value="{{system.bestiary.luckByRank.br5}}" {{#if mythicIsFloodBestiary}}disabled{{/if}} /></td>
                  </tr>
                </tbody>
              </table>
            </section>
          </div>

          <section class="mythic-bestiary-panel">
            <h2>Profile And Modifiers</h2>
