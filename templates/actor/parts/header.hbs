<header class="mythic-sticky-header panel">
  <div class="mythic-header-grid">
    <section class="mythic-header-column left">
      <div class="mythic-header-row">
        <label>Character Name</label>
        <input name="name" type="text" value="{{actor.name}}" />
      </div>
      <div class="mythic-header-row">
        <label>Faction</label>
        {{#if mythicHeader.locks.faction}}
          <input type="hidden" name="system.header.faction" value="{{mythicHeader.values.faction}}" />
          <input type="text" value="{{mythicHeader.values.faction}}" readonly class="mythic-header-locked" />
        {{else}}
          <select name="system.header.faction">
            <option value=""{{#unless mythicHeader.values.faction}} selected{{/unless}}></option>
            {{selectOptions mythicFactionSelectOptions selected=mythicHeader.values.faction}}
          </select>
        {{/if}}
      </div>
      <div class="mythic-header-row">
        <label>Soldier Type</label>
        <input name="system.header.soldierType" type="text" value="{{mythicHeader.values.soldierType}}" {{#if mythicHeader.locks.soldierType}}readonly class="mythic-header-locked"{{/if}} />
      </div>
      <div class="mythic-header-row">
        <label>Rank</label>
        <input name="system.header.rank" type="text" value="{{mythicHeader.values.rank}}" {{#if mythicHeader.locks.rank}}readonly class="mythic-header-locked"{{/if}} />
      </div>
      <div class="mythic-header-row">
        <label>Size</label>
        <input name="system.header.buildSize" type="text" value="{{mythicHeader.values.buildSize}}" {{#if mythicHeader.locks.buildSize}}readonly class="mythic-header-locked"{{/if}} />
      </div>
      <div class="mythic-header-row">
        <label>Specialisation</label>
        <input name="system.header.specialisation" type="text" value="{{mythicHeader.values.specialisation}}" {{#if mythicHeader.locks.specialisation}}readonly class="mythic-header-locked"{{/if}} />
      </div>
    </section>

    <section class="mythic-header-center">
      <img src="{{mythicLogo}}" alt="Faction Logo" class="mythic-faction-logo" />
    </section>

    <section class="mythic-header-column right">
      <div class="mythic-header-row">
        <label>Player Name</label>
        <input name="system.header.playerName" type="text" value="{{mythicHeader.values.playerName}}" {{#if mythicHeader.locks.playerName}}readonly class="mythic-header-locked"{{/if}} />
      </div>
      <div class="mythic-header-row">
        <label>Race</label>
        <input name="system.header.race" type="text" value="{{mythicHeader.values.race}}" {{#if mythicHeader.locks.race}}readonly class="mythic-header-locked"{{/if}} />
      </div>
      <div class="mythic-header-row">
        <label>Upbringing</label>
        <input name="system.header.upbringing" type="text" value="{{mythicHeader.values.upbringing}}" {{#if mythicHeader.locks.upbringing}}readonly class="mythic-header-locked"{{/if}} />
      </div>
      <div class="mythic-header-row">
        <label>Environment</label>
        <input name="system.header.environment" type="text" value="{{mythicHeader.values.environment}}" {{#if mythicHeader.locks.environment}}readonly class="mythic-header-locked"{{/if}} />
      </div>
      <div class="mythic-header-row">
        <label>Lifestyle</label>
        <input name="system.header.lifestyle" type="text" value="{{mythicHeader.values.lifestyle}}" {{#if mythicHeader.locks.lifestyle}}readonly class="mythic-header-locked"{{/if}} />
      </div>
      <div class="mythic-header-row">
        <label>Gender</label>
        <input name="system.header.gender" type="text" value="{{mythicHeader.values.gender}}" {{#if mythicHeader.locks.gender}}readonly class="mythic-header-locked"{{/if}} />
      </div>
    </section>
  </div>
</header>
