<div class="tab advancements" data-group="primary" data-tab="advancements">
  <div class="ccadv-subtabs" role="tablist" aria-label="Character Creation and Advancement sections">
    <button type="button" class="action-btn ccadv-subtab-btn {{#if mythicCcAdv.isCreationActive}}is-active{{/if}}" data-subtab="creation" aria-selected="{{#if mythicCcAdv.isCreationActive}}true{{else}}false{{/if}}">Character Creation</button>
    <button type="button" class="action-btn ccadv-subtab-btn {{#if mythicCcAdv.isAdvancementActive}}is-active{{/if}}" data-subtab="advancement" aria-selected="{{#if mythicCcAdv.isAdvancementActive}}true{{else}}false{{/if}}">Advancement</button>
  </div>

  <div class="ccadv-content-scroll">
    <div class="ccadv-panel {{#unless mythicCcAdv.isCreationActive}}is-hidden{{/unless}}" data-subtab-panel="creation">
      <div class="mythic-phase4-card full-width ccadv-creation-lock-status {{#if mythicCcAdv.isCharacterCreationComplete}}is-finalized{{else}}is-open{{/if}}">
        {{#if mythicCcAdv.isCharacterCreationComplete}}
          <p class="ccadv-note"><strong>Character Creation Status:</strong> Finalized and locked for players.</p>
          <p class="ccadv-note">Players can still view this tab, but only a GM can unlock edits.</p>
        {{else}}
          <p class="ccadv-note"><strong>Character Creation Status:</strong> Open for editing.</p>
        {{/if}}
        {{#if mythicCcAdv.userIsGM}}
          <button type="button" class="action-btn cc-toggle-lock-btn">{{#if mythicCcAdv.isCharacterCreationComplete}}Unlock Character Creation{{else}}Lock Character Creation{{/if}} (GM)</button>
        {{/if}}
      </div>

      <div class="ccadv-creation-lockable {{#if mythicCcAdv.isCreationLocked}}is-locked{{/if}}" {{#if mythicCcAdv.isCreationLocked}}inert{{/if}}>
      <details class="ccadv-stage" data-collapse-key="ccadv-creation-starting-xp" open>
        <summary>1. Starting XP</summary>
        <div class="mythic-phase4-card full-width">
          <div class="mythic-phase4-field-grid compact ccadv-starting-xp-row">
            <div class="mythic-mini-field"><span>XP Earned</span><input type="number" min="0" name="system.advancements.xpEarned" value="{{mythicAdvancements.earned}}" {{#unless mythicCcAdv.canEditStartingXp}}readonly{{/unless}} /></div>
            <div class="mythic-mini-field"><span>XP Spent</span><input type="number" min="0" name="system.advancements.xpSpent" value="{{mythicAdvancements.spent}}" {{#unless mythicCcAdv.canEditStartingXp}}readonly{{/unless}} /></div>
            <div class="mythic-phase4-stat"><span>XP Available</span><strong>{{mythicAdvancements.available}}</strong></div>
          </div>
          {{#unless mythicCcAdv.canEditStartingXp}}
            <p class="ccadv-note">Starting XP is locked by world settings and is awarded by the GM. Ask a GM to enable player editing if needed.</p>
          {{/unless}}
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-creation-soldier-type" open>
        <summary>2. Soldier Type Selection</summary>
        <div class="mythic-phase4-card full-width">
          <div class="ccadv-soldier-type-row">
            <div class="mythic-mini-field ccadv-soldier-type-field"><span>Current Soldier Type</span><input type="text" value="{{mythicHeader.values.soldierType}}" readonly /></div>
            <button type="button" class="action-btn compendium-icon-btn creation-open-soldier-types-btn" title="Open Mythic Soldier Types compendium">
              <i class="fas fa-book"></i> +
            </button>
            <p class="ccadv-note">Open the Soldier Types compendium and apply the selected Soldier Type during creation.</p>
            {{#if mythicSoldierTypeScaffold.orionAugmentation.enabled}}
              <p class="ccadv-note"><strong>Orion Scaffold:</strong> {{#if mythicSoldierTypeScaffold.orionAugmentation.notes}}{{mythicSoldierTypeScaffold.orionAugmentation.notes}}{{else}}Becoming an ORION Soldier is scaffolded for Advancement flow and not enforced yet.{{/if}}</p>
            {{/if}}
            {{#if mythicSoldierTypeScaffold.naturalArmorScaffold.enabled}}
              <p class="ccadv-note"><strong>Natural Armor Scaffold:</strong> {{#if mythicSoldierTypeScaffold.naturalArmorScaffold.notes}}{{mythicSoldierTypeScaffold.naturalArmorScaffold.notes}}{{else}}Natural Armor is recorded for this Soldier Type but not yet applied automatically to DR.{{/if}}</p>
            {{/if}}
          </div>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-creation-path" open>
        <summary>3. Upbringing / Environment / Lifestyle</summary>
        <div class="mythic-phase4-card full-width creation-path-card">
          <h3>Upbringing, Environment, and Lifestyles</h3>

          <div class="creation-path-grid two-column">
            <div class="creation-path-field">
              <div class="creation-path-row">
                <label>Upbringing</label>
                <div class="creation-dropzone" data-kind="upbringing" title="Drag a Upbringing item here">
                  {{#if mythicAdvancements.creationPath.selectedUpbringingName}}
                    {{mythicAdvancements.creationPath.selectedUpbringingName}}
                  {{else}}
                    Drop Upbringing Here
                  {{/if}}
                </div>
                {{#if mythicAdvancements.creationPath.selectedUpbringingHasChoices}}
                  <button type="button" class="action-btn creation-upbringing-prompt-btn">Choices</button>
                {{/if}}
                <button type="button" class="action-btn compendium-icon-btn creation-open-upbringings-btn" title="Open Upbringings compendium"><i class="fas fa-book"></i> +</button>
                <button type="button" class="action-btn creation-clear-btn" data-kind="upbringing">Clear</button>
              </div>
              {{#if mythicAdvancements.creationPath.upbringingRestrictionLabel}}
                <div class="creation-path-meta">
                  <span class="creation-path-pill warning">{{mythicAdvancements.creationPath.upbringingRestrictionLabel}}</span>
                </div>
              {{/if}}
              {{#if mythicAdvancements.creationPath.upbringingChoicePills.length}}
                <div class="creation-path-meta">
                  {{#each mythicAdvancements.creationPath.upbringingChoicePills}}
                    <span class="creation-path-pill">{{this}}</span>
                  {{/each}}
                </div>
              {{/if}}
            </div>

            <div class="creation-path-field">
              <div class="creation-path-row">
                <label>Environment</label>
                <div class="creation-dropzone" data-kind="environment" title="Drag an Environment item here">
                  {{#if mythicAdvancements.creationPath.selectedEnvironmentName}}
                    {{mythicAdvancements.creationPath.selectedEnvironmentName}}
                  {{else}}
                    Drop Environment Here
                  {{/if}}
                </div>
                {{#if mythicAdvancements.creationPath.selectedEnvironmentHasChoices}}
                  <button type="button" class="action-btn creation-environment-prompt-btn">Choices</button>
                {{/if}}
                <button type="button" class="action-btn compendium-icon-btn creation-open-environments-btn" title="Open Environments compendium"><i class="fas fa-book"></i> +</button>
                <button type="button" class="action-btn creation-clear-btn" data-kind="environment">Clear</button>
              </div>
              <div class="creation-path-meta">
                {{#each mythicAdvancements.creationPath.environmentMetaPills}}
                  <span class="creation-path-pill">{{this}}</span>
                {{/each}}
                {{#unless mythicAdvancements.creationPath.selectedEnvironmentIsAllowed}}
                  <span class="creation-path-pill warning">Invalid for upbringing</span>
                {{/unless}}
              </div>
            </div>
          </div>

          <div class="creation-path-lifestyles">
            <div class="creation-path-lifestyle-header-row">
              <h4>Lifestyles (up to 3)</h4>
              <button type="button" class="action-btn compendium-icon-btn creation-open-lifestyles-btn" title="Open Lifestyles compendium"><i class="fas fa-book"></i> +</button>
            </div>

            {{#each mythicAdvancements.creationPath.lifestyles}}
              <div class="creation-lifestyle-slot">
                <div class="creation-path-row creation-path-row-lifestyle">
                  <label>Lifestyle {{slotNumber}}</label>
                  <div class="creation-dropzone" data-kind="lifestyle" data-slot-index="{{slotIndex}}" title="Drag a Lifestyle item here">
                    {{#if lifestyleName}}
                      {{lifestyleName}}
                    {{else}}
                      Drop Lifestyle Here
                    {{/if}}
                  </div>
                  <button type="button" class="action-btn creation-lifestyle-prompt-btn" data-slot-index="{{slotIndex}}">Variant</button>
                  {{#if hasVariantChoices}}
                    <button type="button" class="action-btn creation-lifestyle-choice-btn" data-slot-index="{{slotIndex}}">Choices</button>
                  {{/if}}
                  <button type="button" class="action-btn creation-clear-btn" data-kind="lifestyle" data-slot-index="{{slotIndex}}">Clear</button>
                </div>

                {{#if metaPills.length}}
                  <div class="creation-path-meta">
                    {{#each metaPills}}
                      <span class="creation-path-pill">{{this}}</span>
                    {{/each}}
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-creation-characteristics" open>
        <summary>4. Characteristics Builder</summary>
        {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/characteristics-builder.hbs"}}
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-creation-specialization" open>
        <summary>5. Specialization Pack Selection</summary>
        {{#if mythicSpecialization.isSmartAi}}
          <div class="mythic-smart-ai-spec-panel">
            <div class="mythic-smart-ai-spec-header">
              <div class="mythic-core-identity-block mythic-smart-ai-spec-identity-block" title="Cognitive Pattern: The architectural framework governing how a Smart AI processes information, prioritizes decision pathways, and develops emergent decision heuristics.">
                <div class="mythic-core-identity-title">{{#if mythicSpecialization.cognitivePattern}}{{mythicSpecialization.cognitivePattern}}{{else}}Not Yet Generated{{/if}}</div>
                <div class="mythic-core-identity-meta">UNSC SMART AI <span class="mythic-core-identity-status">Spec Locked</span></div>
              </div>
            </div>
            <p class="ccadv-note">Smart AIs do not receive a Specialization Pack. The Cognitive Pattern system replaces Specialization for this soldier type.</p>
            {{#if mythicSpecialization.oniData}}
              <details class="mythic-oni-classification-details">
                <summary class="mythic-oni-classification-summary">ONI Classification (Internal)</summary>
                <div class="mythic-oni-classification-block">
                  <div class="mythic-oni-field"><span>ONI Heuristic Model</span><span>{{mythicSpecialization.oniData.model}}</span></div>
                  <div class="mythic-oni-field"><span>Logic Structure</span><span>{{mythicSpecialization.oniData.logicStructure}}</span></div>
                  <div class="mythic-oni-field"><span>AI Serial</span><span>{{mythicSpecialization.oniData.serial}}</span></div>
                </div>
              </details>
            {{/if}}
          </div>
        {{else}}
          <div class="mythic-phase4-grid two-column">
            <div class="mythic-phase4-card">
              <h3>Selection</h3>
              <label class="mythic-training-stack">
                <span>Specialization Pack</span>
                <select name="system.specialization.selectedKey" {{#unless mythicSpecialization.canChange}}disabled{{/unless}}>
                  <option value="">Select pack...</option>
                  {{#each mythicSpecialization.options as |opt|}}
                    <option value="{{opt.value}}"{{#if opt.selected}} selected{{/if}}>{{opt.label}}</option>
                  {{/each}}
                </select>
              </label>
              <button type="button" class="action-btn specialization-confirm-btn" {{#unless mythicSpecialization.canChange}}disabled{{/unless}}>Confirm Specialization</button>
              {{#if mythicSpecialization.isBlockedBySoldierType}}
                <p class="ccadv-note"><strong>Unavailable:</strong> {{mythicSpecialization.blockedReason}}</p>
              {{/if}}
              {{#if mythicSpecialization.confirmed}}
                <p class="mythic-specialization-final-note">Finalized. Only a GM can change this selection.</p>
              {{/if}}
            </div>

            <div class="mythic-phase4-card">
              <h3>Pack Details</h3>
              {{#if mythicSpecialization.selected}}
                <div class="mythic-specialization-detail-block">
                  <div><strong>{{mythicSpecialization.selected.name}}</strong>{{#if mythicSpecialization.selected.limited}} <span class="mythic-specialization-limited-tag">Limited Pack</span>{{/if}}</div>
                  {{#if mythicSpecialization.selected.limitedDescription}}
                    <p class="mythic-specialization-limited-description">{{mythicSpecialization.selected.limitedDescription}}</p>
                    <label class="mythic-toggle-row">
                      <input type="checkbox" name="system.specialization.limitedApprovalChecked" {{checked mythicSpecialization.limitedApprovalChecked}} {{#unless mythicSpecialization.canChange}}disabled{{/unless}} />
                      GM and party approved this limited pack.
                    </label>
                  {{/if}}
                  <h4>Abilities</h4>
                  <ul>
                    {{#each mythicSpecialization.selected.abilities as |ability|}}
                      <li>{{ability}}</li>
                    {{/each}}
                  </ul>
                  <h4>Skill Training Grants</h4>
                  <ul>
                    {{#each mythicSpecialization.selected.skillGrants as |grant|}}
                      <li>{{grant.skillName}} ({{grant.tier}})</li>
                    {{/each}}
                  </ul>
                  <p class="ccadv-note">Skill training overlaps are highest-wins and do not stack.</p>
                </div>
              {{else}}
                <p>Select a Specialization Pack to preview its grants.</p>
              {{/if}}
            </div>
          </div>
        {{/if}}
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-creation-outliers" open>
        <summary>6. Outliers</summary>
        <div class="mythic-phase4-card full-width ccadv-outliers-grid">
          <div class="ccadv-outliers-list">
            <h3>Available Outliers</h3>
            <div class="ccadv-outliers-scroll">
              {{#each mythicOutliers.options as |outlier|}}
                <button type="button" class="action-btn outlier-select-btn {{#if outlier.selected}}is-active{{/if}}" data-outlier-key="{{outlier.key}}">{{outlier.name}}</button>
              {{/each}}
            </div>
          </div>

          <div class="ccadv-outliers-detail">
            <h3>Description</h3>
            {{#if mythicOutliers.selected}}
              <h4>{{mythicOutliers.selected.name}}</h4>
              <p class="ccadv-note">{{mythicOutliers.selected.description}}</p>
            {{else}}
              <p class="ccadv-note">Select an Outlier to view its rules text.</p>
            {{/if}}
          </div>

          <div class="ccadv-outliers-purchased">
            <button type="button" class="action-btn outlier-add-btn" {{#unless mythicOutliers.canPurchase}}disabled{{/unless}}>Add Selected Outlier (Burn 1 Luck)</button>
            <p class="ccadv-note">Burned Luck from Outliers: <strong>{{mythicOutliers.burnedLuckCount}}</strong></p>
            <div class="ccadv-outliers-scroll">
              {{#if mythicOutliers.purchased.length}}
                <ul>
                  {{#each mythicOutliers.purchased as |entry|}}
                    <li>
                      #{{entry.index}} {{entry.name}}{{#if entry.choiceLabel}} ({{entry.choiceLabel}}){{/if}}
                      <button type="button" class="action-btn outlier-remove-btn" data-outlier-index="{{entry.listIndex}}">Remove</button>
                    </li>
                  {{/each}}
                </ul>
              {{else}}
                <p class="ccadv-note">No purchased Outliers yet.</p>
              {{/if}}
            </div>
          </div>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-creation-finalize" open>
        <summary>Final Step: Finalize Character Creation</summary>
        <div class="mythic-phase4-card full-width">
          <div class="mythic-phase4-field-grid compact ccadv-starting-xp-row">
            <div class="mythic-mini-field"><span>Total XP Earned</span><input type="number" value="{{mythicCreationFinalizeSummary.xpEarned}}" readonly /></div>
            <div class="mythic-mini-field"><span>Total XP Spent</span><input type="number" value="{{mythicCreationFinalizeSummary.xpSpent}}" readonly /></div>
            <div class="mythic-phase4-stat"><span>XP Remaining</span><strong>{{mythicCreationFinalizeSummary.xpAvailable}}</strong></div>
          </div>
          <p class="ccadv-note">Luck Summary: Burned from Outliers {{mythicCreationFinalizeSummary.burnedLuckCount}} | Current {{mythicCreationFinalizeSummary.luckCurrent}} / Max {{mythicCreationFinalizeSummary.luckMax}}</p>
          {{#if mythicCcAdv.isCharacterCreationComplete}}
            <div class="mythic-phase4-card full-width" style="border: 2px solid var(--mythic-accent); background: rgba(var(--mythic-accent-rgb, 255,200,0), 0.1);">
              <p class="ccadv-note" style="font-weight: bold; color: var(--mythic-accent);">🔒 Character Creation is Finalized</p>
              <p class="ccadv-note">This section is now locked. Changes require GM approval.</p>
              {{#if mythicCcAdv.userIsGM}}
                <button type="button" class="action-btn cc-toggle-lock-btn">🔓 Unlock for Player (GM Only)</button>
              {{/if}}
            </div>
          {{else}}
            <button type="button" class="action-btn cc-move-to-part-two-btn">Move to Part Two</button>
          {{/if}}
        </div>
      </details>
      </div>
    </div>

    <div class="ccadv-panel {{#unless mythicCcAdv.isAdvancementActive}}is-hidden{{/unless}}" data-subtab-panel="advancement">
      <div class="mythic-phase4-card full-width">
        <h3>Part Two: Advancement</h3>
        <p class="ccadv-note">This section handles everything that advances your character both during Character Creation and after Character Creation is finalized.</p>
        <p class="ccadv-note">The Character Creation subtab is only for Character Creation choices. The one exception is Characteristic Advancements, which are also available here in Part Two.</p>
      </div>

      <div class="mythic-phase4-card full-width ccadv-xp-summary-grid">
        <div class="mythic-phase4-stat"><span>Total XP</span><strong>{{mythicAdvancements.xpSummary.total}}</strong></div>
        <div class="mythic-phase4-stat"><span>Spent XP</span><strong>{{mythicAdvancements.xpSummary.spent}}</strong></div>
        <div class="mythic-phase4-stat"><span>Queued XP</span><strong>{{mythicAdvancements.xpSummary.queued}}</strong></div>
        <div class="mythic-phase4-stat"><span>Free XP</span><strong>{{mythicAdvancements.xpSummary.free}}</strong></div>
        <div class="mythic-phase4-stat"><span>After Queue</span><strong>{{mythicAdvancements.xpSummary.remainingAfterQueue}}</strong></div>
        {{#if mythicCcAdv.canEditStartingXp}}
          <button type="button" class="action-btn adv-add-xp-btn">Add XP</button>
        {{/if}}
        {{#unless mythicCcAdv.canEditStartingXp}}
           <p class="ccadv-xp-gm-only-note">Player XP Editing Disabled</p>
        {{/unless}}
      </div>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-abilities" open>
        <summary>1. Purchase Abilities</summary>
        <div class="mythic-phase4-card full-width">
          <div class="ccadv-inline-note-action">
            <p class="ccadv-note">Queue abilities here. They are not granted until finalization.</p>
            <button type="button" class="action-btn adv-open-abilities-btn">Open Abilities Compendium</button>
          </div>
          <div class="ccadv-queue-dropzone" data-adv-queue-drop="ability">Drop Ability Here To Queue</div>
          <div class="ccadv-queue-list">
            {{#if mythicAdvancements.queue.queuedAbilities.length}}
              {{#each mythicAdvancements.queue.queuedAbilities as |entry index|}}
                <div class="ccadv-queue-row">
                  <span>{{entry.name}}</span>
                  <span>{{entry.cost}} XP</span>
                  <button type="button" class="action-btn adv-queue-remove-ability" data-index="{{index}}">Remove</button>
                </div>
              {{/each}}
            {{else}}
              <p class="ccadv-note">No queued abilities.</p>
            {{/if}}
          </div>
          <p class="ccadv-note">Queued XP: {{mythicAdvancements.queue.xpSummary.queued}} | Free XP: {{mythicAdvancements.queue.xpSummary.free}}</p>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-skills" open>
        <summary>2. Purchase Skill Trainings</summary>
        <div class="mythic-phase4-card full-width">
          <div class="ccadv-skill-grid-header">
            <span>Skill</span>
            <span>Official</span>
            <span>Queued</span>
            <span>Adjust</span>
          </div>
          <div class="ccadv-skill-grid-body">
            {{#each mythicAdvancements.queue.skills.rows as |row|}}
              <div class="ccadv-skill-grid-row {{#if row.changed}}is-changed{{/if}}">
                <span>{{row.label}}</span>
                <span>{{row.officialLabel}}</span>
                <span>{{row.queuedLabel}}</span>
                <span>
                  <button type="button" class="action-btn adv-skill-adjust-btn" data-skill-key="{{row.key}}" data-direction="minus">-</button>
                  <button type="button" class="action-btn adv-skill-adjust-btn" data-skill-key="{{row.key}}" data-direction="plus">+</button>
                </span>
              </div>
            {{/each}}
          </div>
          <p class="ccadv-note">Queued XP: {{mythicAdvancements.queue.skills.queuedXp}} | Free XP: {{mythicAdvancements.queue.xpSummary.free}}</p>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-educations" open>
        <summary>3. Education Purchases</summary>
        <div class="mythic-phase4-card full-width">
          <div class="ccadv-inline-note-action">
            <p class="ccadv-note">Queue educations here. They are not granted until finalization.</p>
            <button type="button" class="action-btn adv-open-educations-btn">Open Educations Compendium</button>
          </div>
          <div class="ccadv-queue-dropzone" data-adv-queue-drop="education">Drop Education Here To Queue</div>
          <div class="ccadv-queue-list">
            {{#if mythicAdvancements.queue.queuedEducations.length}}
              {{#each mythicAdvancements.queue.queuedEducations as |entry index|}}
                <div class="ccadv-queue-row">
                  <span>{{entry.name}}</span>
                  <select class="adv-queue-education-tier" data-index="{{index}}">
                    <option value="plus5"{{#if entry.isPlus5}} selected{{/if}}>+5</option>
                    <option value="plus10"{{#if entry.isPlus10}} selected{{/if}}>+10</option>
                  </select>
                  <span>{{entry.cost}} XP</span>
                  <button type="button" class="action-btn adv-queue-remove-education" data-index="{{index}}">Remove</button>
                </div>
              {{/each}}
            {{else}}
              <p class="ccadv-note">No queued educations.</p>
            {{/if}}
          </div>
          <p class="ccadv-note">Queued XP: {{mythicAdvancements.queue.xpSummary.queued}} | Free XP: {{mythicAdvancements.queue.xpSummary.free}}</p>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-luck" open>
        <summary>4. Purchase Luck</summary>
        <div class="mythic-phase4-card full-width ccadv-luck-row">
          <label>Queue Luck Points (1500 XP each)</label>
          <input type="number" min="0" max="{{mythicAdvancements.queue.luck.maxQueue}}" step="1" class="adv-luck-queue-input" value="{{mythicAdvancements.queue.luck.queued}}" />
          <span>Current Max: {{mythicAdvancements.queue.luck.official}} / 13</span>
          <span>Queued XP: {{mythicAdvancements.queue.luck.queuedXp}}</span>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-wounds" open>
        <summary>5. Purchase Wound Upgrades</summary>
        <div class="mythic-phase4-card full-width ccadv-wounds-row">
          <button type="button" class="action-btn adv-wound-adjust-btn" data-direction="minus">-</button>
          <span>Queued Upgrades: {{mythicAdvancements.queue.wounds.queuedPurchases}}</span>
          <button type="button" class="action-btn adv-wound-adjust-btn" data-direction="plus">+</button>
          <span>Queued XP: {{mythicAdvancements.queue.wounds.queuedXp}}</span>
        </div>
        {{#if mythicAdvancements.queue.wounds.queuedTiers.length}}
          <div class="mythic-phase4-card full-width">
            {{#each mythicAdvancements.queue.wounds.queuedTiers as |tier|}}
              <p class="ccadv-note">{{tier.label}}: +{{tier.wounds}} Wounds ({{tier.xpCost}} XP)</p>
            {{/each}}
          </div>
        {{/if}}
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-training" open>
        <summary>6. Faction and Weapon Training</summary>
        <div class="mythic-phase4-card full-width ccadv-training-queue-columns">
          <div>
            <h4>Weapon Training</h4>
            {{#each mythicAdvancements.queue.training.weaponRows as |row|}}
              <label class="ccadv-training-queue-row {{#if row.baseline}}is-locked{{/if}}">
                <input type="checkbox" class="adv-training-toggle" data-training-kind="weapon" data-training-key="{{row.key}}" {{checked row.queued}} {{#if row.baseline}}disabled{{/if}} />
                <span>{{row.label}}</span>
                <span>{{#if row.baseline}}Locked{{else if row.queued}}{{row.queuedCost}} XP{{else}}-{{/if}}</span>
              </label>
            {{/each}}
          </div>
          <div>
            <h4>Faction Training</h4>
            {{#each mythicAdvancements.queue.training.factionRows as |row|}}
              <label class="ccadv-training-queue-row {{#if row.baseline}}is-locked{{/if}}">
                <input type="checkbox" class="adv-training-toggle" data-training-kind="faction" data-training-key="{{row.key}}" {{checked row.queued}} {{#if row.baseline}}disabled{{/if}} />
                <span>{{row.label}}</span>
                <span>{{#if row.baseline}}Locked{{else if row.queued}}{{row.queuedCost}} XP{{else}}-{{/if}}</span>
              </label>
            {{/each}}
          </div>
        </div>
        <p class="ccadv-note">Queued XP: {{mythicAdvancements.queue.training.queuedXp}} | Free XP: {{mythicAdvancements.queue.xpSummary.free}}</p>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-characteristics" open>
        <summary>7. Characteristic Advancements (Preview Only Until Finalized)</summary>
        <div class="mythic-phase4-card full-width">
          <div class="ccadv-char-grid-header">
            <span>Characteristic</span>
            <span>Official</span>
            <span>Advancement</span>
            <span>Other</span>
            <span>Preview</span>
          </div>
          {{#each mythicAdvancements.queue.characteristics.rows as |row|}}
            <div class="ccadv-char-grid-row {{#if row.changed}}is-changed{{/if}}">
              <span>{{row.label}}</span>
              <span>{{row.officialScore}}</span>
              <span>
                <input type="number" min="{{row.officialAdvancement}}" step="5" class="adv-char-adv-select" data-characteristic-key="{{row.key}}" value="{{row.queuedAdvancement}}" />
              </span>
              <span>
                <input type="number" min="0" step="1" class="adv-char-other-input" data-characteristic-key="{{row.key}}" value="{{row.queuedOther}}" />
              </span>
              <span>{{row.previewScore}}</span>
            </div>
          {{/each}}
          <p class="ccadv-note">Queued XP: {{mythicAdvancements.queue.characteristics.queuedXp}} | Free XP: {{mythicAdvancements.queue.xpSummary.free}}</p>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-languages" open>
        <summary>8. Languages</summary>
        <div class="mythic-phase4-card full-width">
          <p class="ccadv-note">Language Cap: {{mythicAdvancements.queue.languages.capacity}} (INT Mod {{mythicAdvancements.queue.languages.intModifier}} + Bonus {{mythicAdvancements.queue.languages.capacityBonus}})</p>
          {{#if mythicCcAdv.isCharacterCreationComplete}}
            <p class="ccadv-note">Be sure there is enough in-character time to justify learning a new language.</p>
          {{/if}}
          <div class="ccadv-language-input-row">
            <input type="text" class="adv-language-input" placeholder="Type language name" />
            <button type="button" class="action-btn adv-language-add-btn">Queue Language</button>
          </div>
          <div class="ccadv-language-columns">
            <div>
              <h4>Known Languages</h4>
              {{#if mythicAdvancements.queue.languages.official.length}}
                <ul>
                  {{#each mythicAdvancements.queue.languages.official as |language|}}
                    <li>{{language}}</li>
                  {{/each}}
                </ul>
              {{else}}
                <p class="ccadv-note">No known languages yet.</p>
              {{/if}}
            </div>
            <div>
              <h4>Queued Languages</h4>
              {{#if mythicAdvancements.queue.languages.queued.length}}
                <ul>
                  {{#each mythicAdvancements.queue.languages.queued as |language index|}}
                    <li>{{language}} <button type="button" class="action-btn adv-language-remove-btn" data-index="{{index}}">Remove</button></li>
                  {{/each}}
                </ul>
              {{else}}
                <p class="ccadv-note">No queued languages.</p>
              {{/if}}
            </div>
          </div>
          <p class="ccadv-note">Queued XP: {{mythicAdvancements.queue.languages.queuedXp}} | Free XP: {{mythicAdvancements.queue.xpSummary.free}}</p>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-rank-support" open>
        <summary>9. Rank and Support Point Calculations</summary>
        <div class="mythic-phase4-grid two-column">
          <div class="mythic-phase4-card">
            <h3>Unlocked Features</h3>
            <textarea name="system.advancements.unlockedFeatures" rows="8">{{mythicSystem.advancements.unlockedFeatures}}</textarea>
          </div>
          <div class="mythic-phase4-card">
            <h3>Spend Log</h3>
            <textarea name="system.advancements.spendLog" rows="8">{{mythicSystem.advancements.spendLog}}</textarea>
          </div>
        </div>
      </details>

      <details class="ccadv-stage" data-collapse-key="ccadv-adv-finalize-cc" open>
        <summary>FINALIZATION / PURCHASE</summary>
        <div class="mythic-phase4-card full-width">
          <h3>Queued Purchases Summary</h3>
          {{#if mythicAdvancements.queue.summaryRows.length}}
            <ul>
              {{#each mythicAdvancements.queue.summaryRows as |row|}}
                <li>{{row.label}}: {{row.cost}} XP</li>
              {{/each}}
            </ul>
          {{else}}
            <p class="ccadv-note">No queued purchases yet.</p>
          {{/if}}

          <p class="ccadv-note">Queued XP: <strong>{{mythicAdvancements.queue.xpSummary.queued}}</strong> | Free XP: <strong>{{mythicAdvancements.queue.xpSummary.free}}</strong> | Remaining After Queue: <strong>{{mythicAdvancements.queue.xpSummary.remainingAfterQueue}}</strong></p>

          {{#if mythicCcAdv.isCharacterCreationComplete}}
            {{#if mythicAdvancements.queue.hasQueuedPurchases}}
              <button type="button" class="action-btn adv-purchase-btn">Purchase Advancements</button>
            {{else}}
              <p class="ccadv-note">Character Creation is finalized. Queue purchases above, then click <strong>Purchase Advancements</strong>.</p>
            {{/if}}
          {{else}}
            <button type="button" class="action-btn cc-finalize-btn">Finalize Character Creation</button>
          {{/if}}
        </div>
      </details>
    </div>
  </div>
</div>
