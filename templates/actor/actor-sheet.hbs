<form class="{{cssClass}} mythic-character-sheet{{#if mythicSidebarCollapsed}} sidebar-collapsed{{/if}}" data-faction="{{mythicFactionIndex}}" autocomplete="off">
  <aside class="sheet-nav">
    <button class="sidebar-toggle action-btn" type="button" title="Toggle Sidebar Width">
      <i class="fas {{#if mythicSidebarCollapsed}}fa-angles-right{{else}}fa-angles-left{{/if}}"></i>
    </button>
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item" data-tab="main" title="Main">
        <i class="fas fa-user"></i>
        <span>Main</span>
      </a>
      <a class="item" data-tab="biography" title="Biography">
        <i class="fas fa-book-open"></i>
        <span>Biography</span>
      </a>
      <a class="item" data-tab="setup" title="Setup">
        <i class="fas fa-gear"></i>
        <span>Setup</span>
      </a>
    </nav>
  </aside>

  <section class="sheet-content">
    <header class="mythic-sticky-header panel">
      <div class="mythic-header-grid">
        <section class="mythic-header-column left">
          <div class="mythic-header-row">
            <label>Character Name</label>
            <input name="name" type="text" value="{{actor.name}}" />
          </div>
          <div class="mythic-header-row">
            <label>Faction</label>
            <select name="system.header.faction">
              {{selectOptions mythicFactionSelectOptions selected=actor.system.header.faction}}
            </select>
          </div>
          <div class="mythic-header-row">
            <label>Soldier Type</label>
            <input name="system.header.soldierType" type="text" value="{{actor.system.header.soldierType}}" />
          </div>
          <div class="mythic-header-row">
            <label>Rank</label>
            <input name="system.header.rank" type="text" value="{{actor.system.header.rank}}" />
          </div>
          <div class="mythic-header-row">
            <label>Size</label>
            <input name="system.header.buildSize" type="text" value="{{actor.system.header.buildSize}}" />
          </div>
          <div class="mythic-header-row">
            <label>Specialisation</label>
            <input name="system.header.specialisation" type="text" value="{{actor.system.header.specialisation}}" />
          </div>
        </section>

        <section class="mythic-header-center">
          <img src="{{mythicLogo}}" alt="Faction Logo" class="mythic-faction-logo" />
        </section>

        <section class="mythic-header-column right">
          <div class="mythic-header-row">
            <label>Player Name</label>
            <input name="system.header.playerName" type="text" value="{{actor.system.header.playerName}}" />
          </div>
          <div class="mythic-header-row">
            <label>Race</label>
            <input name="system.header.race" type="text" value="{{actor.system.header.race}}" />
          </div>
          <div class="mythic-header-row">
            <label>Upbringing</label>
            <input name="system.header.upbringing" type="text" value="{{actor.system.header.upbringing}}" />
          </div>
          <div class="mythic-header-row">
            <label>Environment</label>
            <input name="system.header.environment" type="text" value="{{actor.system.header.environment}}" />
          </div>
          <div class="mythic-header-row">
            <label>Lifestyle</label>
            <input name="system.header.lifestyle" type="text" value="{{actor.system.header.lifestyle}}" />
          </div>
          <div class="mythic-header-row">
            <label>Gender</label>
            <input name="system.header.gender" type="text" value="{{actor.system.header.gender}}" />
          </div>
        </section>
      </div>
    </header>

    <div class="tab main" data-group="primary" data-tab="main">
      <section class="panel">
        <h2>Characteristics</h2>

        <div class="characteristics-strip">
          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="str" data-label="STR" title="Strength">STR</button>
            <input name="system.characteristics.str" type="number" min="0" value="{{actor.system.characteristics.str}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "str"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="tou" data-label="TOU" title="Toughness">TOU</button>
            <input name="system.characteristics.tou" type="number" min="0" value="{{actor.system.characteristics.tou}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "tou"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="agi" data-label="AGI" title="Agility">AGI</button>
            <input name="system.characteristics.agi" type="number" min="0" value="{{actor.system.characteristics.agi}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "agi"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="wfm" data-label="WFM" title="Warfare Melee">WFM</button>
            <input name="system.characteristics.wfm" type="number" min="0" value="{{actor.system.characteristics.wfm}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "wfm"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="wfr" data-label="WFR" title="Warfare Ranged">WFR</button>
            <input name="system.characteristics.wfr" type="number" min="0" value="{{actor.system.characteristics.wfr}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "wfr"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="int" data-label="INT" title="Intellect">INT</button>
            <input name="system.characteristics.int" type="number" min="0" value="{{actor.system.characteristics.int}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "int"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="per" data-label="PER" title="Perception">PER</button>
            <input name="system.characteristics.per" type="number" min="0" value="{{actor.system.characteristics.per}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "per"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="crg" data-label="CRG" title="Courage">CRG</button>
            <input name="system.characteristics.crg" type="number" min="0" value="{{actor.system.characteristics.crg}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "crg"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="cha" data-label="CHA" title="Charisma">CHA</button>
            <input name="system.characteristics.cha" type="number" min="0" value="{{actor.system.characteristics.cha}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "cha"}}</div>
          </div>

          <div class="characteristic-block">
            <button class="roll-characteristic" type="button" data-characteristic="ldr" data-label="LDR" title="Leadership">LDR</button>
            <input name="system.characteristics.ldr" type="number" min="0" value="{{actor.system.characteristics.ldr}}" />
            <div class="characteristic-modifier">{{lookup mythicCharacteristicModifiers "ldr"}}</div>
          </div>
        </div>
      </section>

      <section class="panel mythic-derived-panel">
        <div class="mythic-derived-4col">

          <!-- Mythic Characteristics | ~20% -->
          <details class="mythic-derived-card" data-collapse-key="mythic-card" open>
            <summary>Mythic</summary>
            <div class="mythic-mini-strip">
              <div class="mythic-mini-block">
                <div class="mythic-mini-label">STR</div>
                <input type="number" min="0" name="system.mythic.characteristics.str" value="{{mythicDerived.mythicCharacteristics.str}}" />
              </div>
              <div class="mythic-mini-block">
                <div class="mythic-mini-label">TOU</div>
                <input type="number" min="0" name="system.mythic.characteristics.tou" value="{{mythicDerived.mythicCharacteristics.tou}}" />
              </div>
              <div class="mythic-mini-block">
                <div class="mythic-mini-label">AGI</div>
                <input type="number" min="0" name="system.mythic.characteristics.agi" value="{{mythicDerived.mythicCharacteristics.agi}}" />
              </div>
            </div>
          </details>

          <!-- Character Movement | ~40% -->
          <details class="mythic-derived-card movement-card" data-collapse-key="movement-card" open>
            <summary>Character Movement</summary>
            <div class="movement-strip">
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.movement.half}}</div>
                <div class="movement-label">Half</div>
              </div>
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.movement.full}}</div>
                <div class="movement-label">Full</div>
              </div>
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.movement.charge}}</div>
                <div class="movement-label">Charge</div>
              </div>
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.movement.run}}</div>
                <div class="movement-label">Run</div>
              </div>
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.movement.jump}}</div>
                <div class="movement-label">Jump</div>
              </div>
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.movement.leap}}</div>
                <div class="movement-label">Leap</div>
              </div>
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.movement.sprint}}</div>
                <div class="movement-label">Sprint</div>
              </div>
            </div>
            <details class="movement-reference" data-collapse-key="movement-reference">
              <summary>Movement Reference</summary>
              <div class="movement-ref-content">
                <p><strong>Jump Distance:</strong> {{mythicDerived.movement.jump}} m. This is the maximum vertical height your character can jump.</p>
                <p><strong>Leap Distance:</strong> {{mythicDerived.movement.leap}} m. This is the maximum horizontal distance your character can clear.</p>
                <p><strong>Climb Speed:</strong> Full Action up to {{mythicDerived.movement.climbNoTest}} m with no test. Up to {{mythicDerived.movement.climbWithTest}} m with a Climb Test.</p>
                <p><strong>Jump Bonus While Moving:</strong> Add +1 m leap distance for every 10 m moved this turn.</p>
                <p><strong>Swim Speed:</strong> {{mythicDerived.movement.swimSpeed}} m/turn (STR MOD, no Mythic).</p>
                <p><strong>Initiative Bonus:</strong> +{{mythicDerived.movement.initiativeBonus}} (Mythic AGI ÷ 2, min 1).</p>
                <hr />
                <p><strong>Simple Climb:</strong> Hands-free = no test. Hurried or one-handed: −10 Test. Fail = no progress; 2+ DOF = fall.</p>
                <p><strong>Difficult Climb:</strong> Climb Test required. Abseiling/harnessing: +40 and doubles Climb Speed.</p>
                <hr />
                <p><strong>Simple Swim:</strong> Hands-free, calm water = no test. Hurried or carrying: −10 Test. Fail = Speed halved; 2+ DOF = no distance.</p>
                <p><strong>Swim Weight Penalties:</strong> &gt;50% Carry: −10 / −1 spd &nbsp;·&nbsp; &gt;75%: −30 / −2 spd &nbsp;·&nbsp; ≥90%: −50 / −3 spd &nbsp;·&nbsp; Over-encumbered: can't swim without flotation.</p>
                <p><strong>Swim Endurance:</strong> TOU MOD hours; then Toughness Test per hour (cumulative −10). Fail: +1 Fatigue per DOF.</p>
              </div>
            </details>
          </details>

          <!-- Perceptive Range | ~20% -->
          <details class="mythic-derived-card" data-collapse-key="sight-card" open>
            <summary>Sight</summary>
            <div class="movement-strip">
              <div class="movement-block movement-block-wide">
                <div class="movement-value">{{mythicDerived.perceptiveRange.standard}}</div>
                <div class="movement-label">PER Range</div>
              </div>
            </div>
            <details class="movement-reference" data-collapse-key="sight-reference">
              <summary>Lighting &amp; Range Penalties</summary>
              <div class="movement-ref-content">
                <div class="movement-ref-row">
                  <span>Bright / Low-Light</span>
                  <span>{{mythicDerived.perceptiveRange.brightOrLowLight}} m</span>
                </div>
                <div class="movement-ref-row">
                  <span>Blinding / Darkness</span>
                  <span>{{mythicDerived.perceptiveRange.blindingOrDarkness}} m</span>
                </div>
                <div class="movement-ref-row">
                  <span>−20 To Hit up to</span>
                  <span>{{mythicDerived.perceptiveRange.penalty20Max}} m</span>
                </div>
                <div class="movement-ref-row">
                  <span>−60 To Hit up to</span>
                  <span>{{mythicDerived.perceptiveRange.penalty60Max}} m</span>
                </div>
                <p>Scopes and sights multiply Perceptive Range (e.g. 2× Scope doubles range).</p>
                <p>Attacks beyond 3× Perceptive Range are impossible.</p>
              </div>
            </details>
          </details>

          <!-- Carrying Capacity | ~20% -->
          <details class="mythic-derived-card" data-collapse-key="weight-card" open>
            <summary>Weight</summary>
            <div class="movement-strip">
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.carryingCapacity.carry}}</div>
                <div class="movement-label">Carry</div>
              </div>
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.carryingCapacity.lift}}</div>
                <div class="movement-label">Lift</div>
              </div>
              <div class="movement-block">
                <div class="movement-value">{{mythicDerived.carryingCapacity.push}}</div>
                <div class="movement-label">Push</div>
              </div>
            </div>
            <details class="movement-reference" data-collapse-key="weight-reference">
              <summary>Gravity</summary>
              <div class="movement-ref-content">
                <div class="movement-ref-row gravity-input-row">
                  <label>Current Gravity</label>
                  <input type="number" name="system.gravity" min="0" max="4" step="0.1" value="{{mythicGravityValue}}" />
                </div>
                <p>Gravity modifies Carry, Lift, Push, Jump, Leap, and Climb Speed (÷ gravity). Ultra-High/Low gravity also applies AGI penalties. Zero-G: normal movement requires a surface or propulsion to push off.</p>
              </div>
            </details>
          </details>

        </div>
      </section>
    </div>

    <div class="tab biography" data-group="primary" data-tab="biography">
      <section class="panel biography-tab">
        <h2>Biography</h2>

        <details class="bio-section" open>
          <summary>Physical Description</summary>
          <div class="bio-grid">
            <div class="bio-portrait-panel">
              <img src="{{actor.img}}" alt="Character Portrait" class="bio-portrait-preview" />
              <div class="bio-row">
                <label>Portrait</label>
                <input type="text" name="img" value="{{actor.img}}" />
                <button class="file-picker action-btn" type="button" data-type="image" data-target="img" title="Browse Files">
                  <i class="fas fa-file-import"></i>
                </button>
              </div>
            </div>

            <div class="bio-fields">
              <div class="bio-row">
                <label>Height</label>
                <input type="text" name="system.biography.physical.height" value="{{mythicBiography.physical.height}}" />
              </div>
              <div class="bio-row">
                <label>Weight</label>
                <input type="text" name="system.biography.physical.weight" value="{{mythicBiography.physical.weight}}" />
              </div>
              <div class="bio-row">
                <label>Age</label>
                <input type="text" name="system.biography.physical.age" value="{{mythicBiography.physical.age}}" />
              </div>
              <div class="bio-row">
                <label>Gender</label>
                <input type="text" name="system.biography.physical.gender" value="{{actor.system.header.gender}}" readonly />
              </div>
              <div class="bio-row">
                <label>Hair</label>
                <input type="text" name="system.biography.physical.hair" value="{{mythicBiography.physical.hair}}" />
              </div>
              <div class="bio-row">
                <label>Skin</label>
                <input type="text" name="system.biography.physical.skin" value="{{mythicBiography.physical.skin}}" />
              </div>
              <div class="bio-row">
                <label>Eyes</label>
                <input type="text" name="system.biography.physical.eyes" value="{{mythicBiography.physical.eyes}}" />
              </div>
              <div class="bio-row">
                <label>Defining Features</label>
                <input type="text" name="system.biography.physical.definingFeatures" value="{{mythicBiography.physical.definingFeatures}}" />
              </div>
            </div>
          </div>

          <div class="bio-block">
            <label>General Description</label>
            <textarea name="system.biography.physical.generalDescription" rows="5">{{mythicBiography.physical.generalDescription}}</textarea>
          </div>

          <div class="bio-repeating-list">
            {{#each mythicBiography.physical.extraFields as |entry index|}}
              <div class="bio-repeating-item">
                <div class="bio-row">
                  <label>Field Name</label>
                  <input type="text" name="system.biography.physical.extraFields.{{index}}.label" value="{{entry.label}}" placeholder="Custom field name" />
                </div>
                <div class="bio-block">
                  <label>Value</label>
                  <textarea name="system.biography.physical.extraFields.{{index}}.value" rows="3">{{entry.value}}</textarea>
                </div>
                <button class="bio-remove-entry action-btn" type="button" data-path="biography.physical.extraFields" data-index="{{index}}">Remove</button>
              </div>
            {{/each}}
            <button class="bio-add-entry action-btn" type="button" data-path="biography.physical.extraFields">Add Physical Field</button>
          </div>
        </details>

        <details class="bio-section" open>
          <summary>History</summary>

          <div class="bio-row">
            <label>Birthdate</label>
            <input type="text" name="system.biography.history.birthdate" value="{{mythicBiography.history.birthdate}}" placeholder="YYYY-MM-DD or narrative format" />
          </div>
          <div class="bio-row">
            <label>Birthplace</label>
            <input type="text" name="system.biography.history.birthplace" value="{{mythicBiography.history.birthplace}}" placeholder="Ex: New Mombasa, Earth" />
          </div>

          <h3>Education</h3>
          <div class="bio-repeating-list">
            {{#each mythicBiography.history.education as |entry index|}}
              <div class="bio-repeating-item">
                <div class="bio-row">
                  <label>Institution</label>
                  <input type="text" name="system.biography.history.education.{{index}}.institution" value="{{entry.institution}}" placeholder="Ex: Reach Military Academy" />
                </div>
                <div class="bio-block">
                  <label>Notes</label>
                  <textarea name="system.biography.history.education.{{index}}.notes" rows="2">{{entry.notes}}</textarea>
                </div>
                <button class="bio-remove-entry action-btn" type="button" data-path="biography.history.education" data-index="{{index}}">Remove</button>
              </div>
            {{/each}}
            <button class="bio-add-entry action-btn" type="button" data-path="biography.history.education">Add Education Entry</button>
          </div>

          <h3>Residence / Service Posting History</h3>
          <div class="bio-repeating-list">
            {{#each mythicBiography.history.dutyStations as |entry index|}}
              <div class="bio-repeating-item bio-posting-item">
                <div class="bio-row">
                  <label>Location</label>
                  <input type="text" name="system.biography.history.dutyStations.{{index}}.location" value="{{entry.location}}" />
                </div>
                <div class="bio-row">
                  <label>Status</label>
                  <select name="system.biography.history.dutyStations.{{index}}.status">
                    {{selectOptions ../mythicDutyStationStatusOptions selected=entry.status}}
                  </select>
                </div>
                <button class="bio-remove-entry action-btn" type="button" data-path="biography.history.dutyStations" data-index="{{index}}">Remove</button>
              </div>
            {{/each}}
            <button class="bio-add-entry action-btn" type="button" data-path="biography.history.dutyStations">Add Residence / Posting Entry</button>
          </div>
        </details>

        <details class="bio-section" open>
          <summary>Family</summary>
          <div class="bio-repeating-list">
            {{#each mythicBiography.family as |entry index|}}
              <div class="bio-repeating-item bio-family-item">
                <div class="bio-row">
                  <label>Name</label>
                  <input type="text" name="system.biography.family.{{index}}.name" value="{{entry.name}}" />
                </div>
                <div class="bio-row">
                  <label>Relationship</label>
                  <input type="text" name="system.biography.family.{{index}}.relationship" value="{{entry.relationship}}" />
                </div>
                <button class="bio-remove-entry action-btn" type="button" data-path="biography.family" data-index="{{index}}">Remove</button>
              </div>
            {{/each}}
            <button class="bio-add-entry action-btn" type="button" data-path="biography.family">Add Family Entry</button>
          </div>
        </details>

        <details class="bio-section" open>
          <summary>General Biography</summary>
          <div class="bio-repeating-list">
            {{#each mythicBiography.generalEntries as |entry index|}}
              <div class="bio-repeating-item">
                <div class="bio-row">
                  <label>Field Name</label>
                  <input type="text" name="system.biography.generalEntries.{{index}}.label" value="{{entry.label}}" placeholder="Ex: General Biography" />
                </div>
                <div class="bio-block">
                  <label>Text</label>
                  <textarea name="system.biography.generalEntries.{{index}}.text" rows="6">{{entry.text}}</textarea>
                </div>
                <button class="bio-remove-entry action-btn" type="button" data-path="biography.generalEntries" data-index="{{index}}">Remove</button>
              </div>
            {{/each}}
            <button class="bio-add-entry action-btn" type="button" data-path="biography.generalEntries">Add Biography Field</button>
          </div>
        </details>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="setup">
      <section class="panel">
        <h2>Setup</h2>
        <p>System setup options will go here in later steps.</p>
      </section>
    </div>
  </section>
</form>

