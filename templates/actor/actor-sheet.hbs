{{#if mythicIsVehicleActor}}
<div
  class="mythic-character-sheet mythic-bestiary-shell mythic-vehicle-fallback-sheet mythic-sheet-theme-root"
  data-faction="{{mythicFactionIndex}}"
  data-theme-preset="{{mythicSheetAppearance.preset}}"
  data-panel-style="{{mythicSheetAppearance.panelStyle}}"
  data-portrait-frame="{{mythicSheetAppearance.portraitFrame}}"
  data-banner-style="{{mythicSheetAppearance.banner.style}}"
  data-has-banner="{{#if mythicSheetAppearance.displayBanner}}true{{else}}false{{/if}}">
  <aside class="sheet-nav">
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item" data-tab="vehicle-summary" title="Vehicle Summary">
        <i class="fas fa-truck"></i>
      </a>
      <a class="item" data-tab="vehicle-crew" title="Crew & Complement">
        <i class="fas fa-users"></i>
      </a>
      <a class="item" data-tab="vehicle-cargo" title="Loadout">
        <i class="fas fa-boxes-stacked"></i>
      </a>
      <a class="item" data-tab="vehicle-notes" title="Notes">
        <i class="fas fa-note-sticky"></i>
      </a>
      <a class="item" data-tab="vehicle-settings" title="Settings">
        <i class="fas fa-gear"></i>
      </a>
    </nav>
  </aside>

  <section class="sheet-content">
    <header class="mythic-bestiary-header mythic-bestiary-sticky-header mythic-sticky-header panel mythic-sheet-header-surface">
      <div class="mythic-bestiary-portrait-column">
        <div class="mythic-bestiary-portrait-wrap mythic-sheet-portrait-surface">
          <img class="profile-img mythic-sheet-portrait-image" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}" />
        </div>
        {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/sheet-appearance-banner.hbs"}}
      </div>
      <div class="mythic-bestiary-header-fields">
        <div class="mythic-bestiary-header-title-row">
          <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Vehicle Name" /></h1>
          <div class="mythic-bestiary-header-xp-field">
            <label>Defeat Experience</label>
            <input type="number" name="system.experience" value="{{mythicVehicleSystem.experience}}" />
          </div>
        </div>
        <div class="mythic-bestiary-header-grid">
          <label>
            Nickname
            <input type="text" name="system.designation" value="{{mythicVehicleSystem.designation}}" />
          </label>
          <label>
            Variant
            <input type="text" name="system.variant" value="{{mythicVehicleSystem.variant}}" />
          </label>
          <label>
            Faction
            <select name="system.faction">
              <option value=""{{#unless mythicVehicleSystem.faction}} selected{{/unless}}></option>
              {{selectOptions mythicFactionSelectOptions selected=mythicVehicleSystem.faction}}
            </select>
          </label>
          <label>
            Price
            <input type="number" name="system.price" value="{{mythicVehicleSystem.price}}" />
          </label>
        </div>
        <div class="mythic-bestiary-header-dimensions" style="margin-top:8px; display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:8px;">
          <label>
            Length (m)
            <input type="number" name="system.dimensions.length" value="{{mythicVehicleSystem.dimensions.length}}" />
          </label>
          <label>
            Width (m)
            <input type="number" name="system.dimensions.width" value="{{mythicVehicleSystem.dimensions.width}}" />
          </label>
          <label>
            Height (m)
            <input type="number" name="system.dimensions.height" value="{{mythicVehicleSystem.dimensions.height}}" />
          </label>
          <label class="mythic-vehicle-weight-field">
            Weight
            <div class="mythic-vehicle-weight-input-row">
              <input type="number" min="0" step="{{mythicVehicleDisplayWeightStep}}" name="system.dimensions.weight" value="{{mythicVehicleDisplayWeight}}" />
              <select name="system.dimensions.weightUnit" data-prev-unit="{{mythicVehicleSystem.dimensions.weightUnit}}">
                {{selectOptions mythicVehicleWeightUnitOptions selected=mythicVehicleSystem.dimensions.weightUnit}}
              </select>
            </div>
          </label>
        </div>
      </div>
    </header>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-summary" style="padding:14px 16px;">
      <div class="vehicle-summary-grid">
        {{!--
          <div class="mobility-row">
            <label>Current Speed</label>
            <div class="mobility-value" data-field="system.mythicVehicleSystem.movement.speed.value">{{mythicVehicleSystem.movement.speed.value}}</div>
            <div class="mobility-controls">
              <button class="action-btn" type="button" data-action="decrease-speed">−</button>
              <button class="action-btn" type="button" data-action="increase-speed">+</button>
            </div>
          </div>
          <div class="mobility-row">
            <label>Brake</label>
            <div class="mobility-value" data-field="system.mythicVehicleSystem.movement.brake.value">{{mythicVehicleSystem.movement.brake.value}}</div>
          </div>
          <div class="mobility-row">
            <label>Accelerate</label>
            <div class="mobility-value" data-field="system.mythicVehicleSystem.movement.accelerate.value">{{mythicVehicleSystem.movement.accelerate.value}}</div>
          </div>
          <div class="mobility-row">
            <label>Maneuver</label>
            <div class="mobility-value" data-field="system.mythicVehicleSystem.movement.maneuver.total">{{mythicVehicleSystem.movement.maneuver.total}}</div>
          </div>
          <div class="mobility-actions">
            <button class="action-btn" type="button" data-action="splatter">Splatter</button>
            <button class="action-btn" type="button" data-action="wreck">Wreck</button>
          </div>
          --}}
        {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/vehicle-mobility-panel.hbs"}}

        <div class="panel vehicle-summary-main">
          {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/vehicle-overview-tab.hbs"}}
        </div>

        <section class="panel vehicle-summary-weapons-panel">
          <h2>Weapons</h2>
          <p class="mythic-known-bug-badge"><strong>BUG:</strong> Vehicle weapon ammo deduction is still buggy and may not work properly.</p>

          {{#if mythicVehicleWalker.melee.hasCards}}
            <div class="vehicle-summary-weapons-table vehicle-walker-melee-table">
              <div class="vehicle-summary-weapons-table-body">
                {{#each mythicVehicleWalker.melee.cards as |attack|}}
                <article class="mythic-ready-weapon-card vehicle-summary-weapon-card vehicle-walker-melee-card{{#unless attack.canAttack}} is-disabled{{/unless}}">
                  <div class="vehicle-weapon-strip-row vehicle-weapon-strip-primary">
                    <div class="vehicle-weapon-strip-ident">
                      <span class="vehicle-weapon-slot-badge">{{attack.slotCode}}</span>
                      <div class="vehicle-weapon-strip-title-block">
                        <div class="vehicle-weapon-strip-title-row">
                          <div class="vehicle-weapon-strip-title" title="{{attack.name}}">{{attack.name}}</div>
                        </div>
                        <div class="vehicle-weapon-strip-controller">{{attack.controllingUserLabel}}</div>
                      </div>
                    </div>
                    <div class="vehicle-weapon-strip-mode">{{attack.modeLabel}}</div>
                    <div class="vehicle-weapon-strip-attacks">
                      {{#each attack.actionButtons as |button|}}
                      <button
                        type="button"
                        class="action-btn vehicle-weapon-strip-attack-btn vehicle-walker-melee-attack-btn"
                        data-walker-attack="{{../key}}"
                        data-action="{{button.action}}"
                        title="{{button.title}}"
                        {{#unless ../canAttack}}disabled{{/unless}}>{{button.label}}</button>
                      {{/each}}
                    </div>
                    <span></span>
                  </div>
                  <div class="vehicle-weapon-strip-row vehicle-weapon-strip-secondary">
                    <div class="vehicle-weapon-strip-info">{{attack.rangeSummary}}</div>
                    <div class="vehicle-weapon-strip-info">Damage {{attack.damageLabel}}</div>
                    <div class="vehicle-weapon-strip-info">Modifier {{attack.modifierText}}</div>
                    {{#if attack.specialRules.length}}
                    <div class="vehicle-weapon-strip-badges">
                      {{#each attack.specialRules as |rule|}}
                      <span class="vehicle-weapon-strip-badge is-rule">{{rule}}</span>
                      {{/each}}
                    </div>
                    {{/if}}
                    {{#if attack.disableReason}}
                    <div class="vehicle-weapon-strip-info">{{attack.disableReason}}</div>
                    {{/if}}
                  </div>
                </article>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if mythicVehicleOverview.weapons.hasCards}}
            <div class="vehicle-summary-weapons-table">
              <div class="vehicle-summary-weapons-table-head" aria-hidden="true">
                <span>Weapon</span>
                <span>Mode</span>
                <span>Attacks</span>
                <span>NL</span>
                <span></span>
              </div>

              <div class="vehicle-summary-weapons-table-body">
                {{#each mythicVehicleOverview.weapons.cards as |weapon|}}
                  {{#with weapon}}
                    {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/vehicle-weapon-panel.hbs"}}
                  {{/with}}
                {{/each}}
              </div>
            </div>
          {{else}}
            {{#unless mythicVehicleWalker.melee.hasCards}}
            <div class="vehicle-overview-empty">No mounted weapons assigned.</div>
            {{/unless}}
          {{/if}}
        </section>
      </div>
    </div>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-crew" style="padding:14px 16px;">
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/vehicle-crew-roster.hbs"}}
    </div>

    <div class="tab sheet-tab-scrollable vehicle-loadout-tab" data-group="primary" data-tab="vehicle-cargo" style="padding:14px 16px;">
      <div class="vehicle-loadout-stack">
        <div class="vehicle-loadout-help">
          Use Add Vehicle Weapon to create an emplacement card. Drop weapons onto a specific card to mount them, and drop any equipment into Cargo to keep it as cargo.
        </div>

        <div class="panel vehicle-loadout-panel">
          <div class="vehicle-loadout-header">
            <div>
              <h2>Vehicle Weapons</h2>
              <p class="vehicle-loadout-note">Each card is a single emplacement. Controller and linked settings stay with the emplacement even when no weapon is assigned.</p>
            </div>
            <button type="button" class="action-btn vehicle-emplacement-add-btn">Add Vehicle Weapon</button>
          </div>

          {{#unless mythicVehicleLoadout.hasControllerSlots}}
          <p class="vehicle-loadout-note vehicle-loadout-warning">No operator, gunner, or passenger slots are configured yet. Define crew capacity in Setup before assigning controllers.</p>
          {{/unless}}
          {{#if mythicVehicleLoadout.emplacements.length}}
          <div class="vehicle-emplacement-list">
            {{#each mythicVehicleLoadout.emplacements as |emplacement|}}
            <div class="vehicle-emplacement-card vehicle-weapon-card vehicle-loadout-drop-zone {{#unless emplacement.hasWeapon}}is-empty{{/unless}}" data-vehicle-loadout-drop="emplacement" data-emplacement-id="{{emplacement.id}}">
              <div class="vehicle-emplacement-row vehicle-emplacement-row-primary">
                <div class="vehicle-weapon-title-row">
                  <span class="vehicle-emplacement-label">{{emplacement.label}}</span>
                  {{#if emplacement.hasWeapon}}
                  <div class="mythic-equipment-name-cell vehicle-emplacement-name-cell">
                    <img class="mythic-equipment-icon" src="{{emplacement.weaponImg}}" alt="{{emplacement.weaponFullName}}" />
                    <span class="mythic-equipment-name">{{emplacement.weaponDisplayName}}</span>
                    <button type="button" class="action-btn gear-open-btn vehicle-weapon-edit-btn" data-item-id="{{emplacement.weaponId}}" title="Edit item" aria-label="Edit item"><i class="fas fa-pen-to-square"></i></button>
                  </div>
                  {{else}}
                  <div class="vehicle-emplacement-empty-state">
                    <strong>No weapon assigned</strong>
                    <span>Drop a weapon here to fill this emplacement.</span>
                  </div>
                  {{/if}}
                </div>

                <div class="vehicle-emplacement-controls-inline">
                  <label class="vehicle-emplacement-inline-field">
                    <span class="vehicle-mounted-weapon-field-label">Role</span>
                    <select class="vehicle-loadout-select vehicle-emplacement-field" data-emplacement-id="{{emplacement.id}}" data-field="controllerRole">
                      {{selectOptions emplacement.controllerRoleOptions selected=emplacement.controllerRole}}
                    </select>
                  </label>

                  {{#if emplacement.showControllerPositionField}}
                  <label class="vehicle-emplacement-inline-field">
                    <span class="vehicle-mounted-weapon-field-label">Position</span>
                    <select class="vehicle-loadout-select vehicle-emplacement-field" data-emplacement-id="{{emplacement.id}}" data-field="controllerIndex">
                      {{selectOptions emplacement.controllerPositionOptions selected=emplacement.controllerIndex}}
                    </select>
                  </label>
                  {{/if}}

                  <label class="vehicle-emplacement-inline-field vehicle-emplacement-inline-linked">
                    <span class="vehicle-mounted-weapon-field-label">Linked Weapons</span>
                    <input type="number" min="1" step="1" class="vehicle-loadout-number-input vehicle-emplacement-field" data-emplacement-id="{{emplacement.id}}" data-field="linkedCount" value="{{emplacement.linkedCount}}" />
                  </label>
                  {{#if ../mythicVehicleIsWalker}}
                  <label class="vehicle-emplacement-inline-field">
                    <span class="vehicle-mounted-weapon-field-label">Location</span>
                    <select class="vehicle-loadout-select vehicle-emplacement-field" data-emplacement-id="{{emplacement.id}}" data-field="location">
                      {{selectOptions emplacement.locationOptions selected=emplacement.location}}
                    </select>
                  </label>
                  {{/if}}
                </div>

                <button type="button" class="action-btn vehicle-emplacement-duplicate-btn" data-emplacement-id="{{emplacement.id}}" title="Duplicate slot and weapon" aria-label="Duplicate slot and weapon"><i class="fas fa-clone"></i></button>
                <button type="button" class="action-btn vehicle-emplacement-remove-btn mythic-row-remove" data-emplacement-id="{{emplacement.id}}" title="Delete emplacement" aria-label="Delete emplacement"><i class="fas fa-trash"></i></button>
              </div>

              <div class="vehicle-emplacement-row vehicle-emplacement-row-ammo">
                {{#if emplacement.hasWeapon}}
                  {{#if emplacement.canEditMagazines}}
                  <div class="vehicle-magazine-inline-list" title="{{emplacement.ammoSummaryTitle}}">
                    {{#each emplacement.magazines as |magazine|}}
                    <div class="vehicle-magazine-chip {{#if magazine.isLoaded}}is-loaded{{/if}}">
                      <input type="text" class="vehicle-magazine-field vehicle-magazine-type" data-emplacement-id="{{../id}}" data-magazine-id="{{magazine.id}}" data-field="type" value="{{magazine.type}}" placeholder="Type" />
                      <input type="number" min="0" step="1" class="vehicle-magazine-field vehicle-magazine-count" data-emplacement-id="{{../id}}" data-magazine-id="{{magazine.id}}" data-field="current" value="{{magazine.current}}" title="Rounds remaining" />
                      <span class="vehicle-magazine-max">/ {{magazine.max}}</span>
                      <button type="button" class="action-btn vehicle-magazine-remove-btn" data-emplacement-id="{{../id}}" data-magazine-id="{{magazine.id}}" title="Remove magazine" aria-label="Remove magazine"><i class="fas fa-xmark"></i></button>
                    </div>
                    {{/each}}
                    <button type="button" class="action-btn vehicle-magazine-add-btn" data-emplacement-id="{{emplacement.id}}">+ Add Magazine</button>
                    {{#if emplacement.showReloadButton}}<button type="button" class="action-btn weapon-reload-btn vehicle-weapon-reload-btn" data-item-id="{{emplacement.weaponId}}" data-vehicle-emplacement-id="{{emplacement.id}}">Reload</button>{{/if}}
                  </div>
                  {{else}}
                  <div class="vehicle-emplacement-ammo-fallback" title="{{emplacement.ammoSummaryTitle}}">{{emplacement.ammoFallbackText}}</div>
                  {{/if}}
                {{else}}
                <div class="vehicle-emplacement-ammo-fallback">Assign a weapon to manage magazines.</div>
                {{/if}}
              </div>
            </div>
            {{/each}}
          </div>
          {{else}}
          <p class="vehicle-loadout-empty">No vehicle weapon emplacements yet. Use Add Vehicle Weapon to create a card, then drop a weapon onto it.</p>
          {{/if}}
        </div>

        <div class="panel vehicle-loadout-panel">
          <div class="vehicle-loadout-header">
            <div>
              <h2>Cargo</h2>
              <p class="vehicle-loadout-note">All equipment dropped here stays cargo, including loose weapons, ammunition, armor, and spare gear. Cargo weight only counts this section.</p>
            </div>
            <div class="vehicle-loadout-summary-card">
              <span class="vehicle-loadout-summary-label">Cargo Weight</span>
              <strong>{{mythicVehicleLoadout.cargoWeightLabel}}</strong>
              <span class="vehicle-loadout-summary-meta">{{mythicVehicleLoadout.cargoItemCount}} total</span>
            </div>
          </div>

          <div class="vehicle-cargo-drop-zone vehicle-loadout-drop-zone" data-vehicle-loadout-drop="cargo">
            <strong>Drop Cargo Here</strong>
            <span>Weapons dropped here remain cargo and count toward cargo weight.</span>
          </div>

          {{#if mythicVehicleLoadout.cargoItems.length}}
          <div class="mythic-equipment-list mythic-equipment-table vehicle-loadout-table vehicle-cargo-table">
            <div class="mythic-equipment-row mythic-equipment-header-row">
              <span class="mythic-equipment-header-name">Name</span>
              <span>QTY</span>
              <span>WEIGHT</span>
            </div>
            {{#each mythicVehicleLoadout.cargoItems as |item|}}
            <div class="mythic-equipment-row mythic-equipment-data-row">
              <span class="mythic-equipment-name-cell">
                <img class="mythic-equipment-icon" src="{{item.img}}" alt="{{item.name}}" />
                <span class="mythic-equipment-name">{{item.name}}</span>
                <span class="mythic-equipment-meta">{{item.typeLabel}}</span>
                <span class="mythic-equipment-actions-inline">
                  <button type="button" class="action-btn gear-open-btn" data-item-id="{{item.id}}" title="Edit item" aria-label="Edit item"><i class="fas fa-pen-to-square"></i></button>
                  <button type="button" class="action-btn gear-remove-btn mythic-row-remove" data-item-id="{{item.id}}" data-item-ids="{{item.stackItemIds}}" title="Remove item" aria-label="Remove item"><i class="fas fa-trash"></i></button>
                </span>
              </span>
              <span><input type="number" min="0" step="1" class="gear-quantity-input vehicle-loadout-number-input" data-item-id="{{item.id}}" data-item-ids="{{item.stackItemIds}}" data-kind="vehicle-cargo" value="{{item.quantity}}" /></span>
              <span>{{item.totalWeightLabel}}</span>
            </div>
            {{/each}}
          </div>
          {{else}}
          <p class="vehicle-loadout-empty">No cargo stored on this vehicle yet. Drop equipment into Cargo to start building the loadout.</p>
          {{/if}}
        </div>
      </div>
    </div>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-notes" style="padding:14px 16px;">
      <div class="panel vehicle-notes-panel">
        <h2>Notes</h2>
        <div class="vehicle-notes-editor" data-editor-target="system.notes"></div>
      </div>
    </div>

    <div class="tab sheet-tab-scrollable" data-group="primary" data-tab="vehicle-settings" style="padding:14px 16px;">
      <div class="panel">
        <h2>Setup</h2>
        <div class="setup-grid">
          <div class="panel breakpoints-panel">
            <h3>Breakpoints</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">WEP</div><input class="small-input" type="number" name="system.breakpoints.wep.value" value="{{mythicVehicleSystem.breakpoints.wep.value}}" {{#unless mythicIsGM}}disabled{{/unless}} /></div>
              <div class="compact-field"><div class="field-label">MOB</div><input class="small-input" type="number" name="system.breakpoints.mob.value" value="{{mythicVehicleSystem.breakpoints.mob.value}}" {{#unless mythicIsGM}}disabled{{/unless}} /></div>
              <div class="compact-field"><div class="field-label">ENG</div><input class="small-input" type="number" name="system.breakpoints.eng.value" value="{{mythicVehicleSystem.breakpoints.eng.value}}" {{#unless mythicIsGM}}disabled{{/unless}} /></div>
              <div class="compact-field">
                <div class="field-label">OP</div>
                {{#if mythicVehicleSystem.breakpoints.op.noOptics}}
                <input class="small-input" type="text" value="-" disabled />
                <input type="hidden" name="system.breakpoints.op.value" value="0" {{#unless mythicIsGM}}disabled{{/unless}} />
                {{else}}
                <input class="small-input" type="number" name="system.breakpoints.op.value" value="{{mythicVehicleSystem.breakpoints.op.value}}" {{#unless mythicIsGM}}disabled{{/unless}} />
                {{/if}}
              </div>
              <div class="compact-field"><div class="field-label">HULL</div><input class="small-input" type="number" name="system.breakpoints.hull.value" value="{{mythicVehicleSystem.breakpoints.hull.value}}" {{#unless mythicIsGM}}disabled{{/unless}} /></div>
              <div class="compact-field compact-field-checkbox">
                <div class="field-label">No Optics</div>
                <input type="hidden" name="system.breakpoints.op.noOptics" value="false" {{#unless mythicIsGM}}disabled{{/unless}} />
                <input id="vehicle-{{actor.id}}-no-optics" type="checkbox" name="system.breakpoints.op.noOptics" value="true" {{#if mythicVehicleSystem.breakpoints.op.noOptics}}checked{{/if}} {{#unless mythicIsGM}}disabled{{/unless}} />
              </div>
            </div>
            {{#if mythicVehicleBreakpointManagementEditable}}
              <div class="vehicle-setup-panel-actions">
                <button type="button" class="action-btn vehicle-breakpoints-full-repair-btn">Full Repair</button>
              </div>
            {{/if}}
          </div>

          {{#if mythicVehicleIsWalker}}
          <div class="panel armor-panel vehicle-walker-locations-panel">
            <h3>Armor</h3>
            <div class="vehicle-walker-location-grid">
              {{#each mythicVehicleWalker.locations as |location|}}
              <div class="vehicle-walker-location-card {{location.stateClass}}">
                <input type="hidden" name="{{location.breakpointTypeName}}" value="{{location.breakpointType}}" />
                <div class="vehicle-walker-location-head">
                  <strong>{{location.shortLabel}}</strong>
                  <span>{{location.breakpointType}}</span>
                </div>
                <label>
                  <input class="small-input" type="number" name="{{location.armorName}}" value="{{location.armor}}" />
                </label>
              </div>
              {{/each}}
            </div>
          </div>
          {{else}}
          <div class="panel armor-panel">
            <h3>Armor</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Front</div><input class="small-input" type="number" name="system.armor.front.value" value="{{mythicVehicleSystem.armor.front.value}}" /></div>
              <div class="compact-field"><div class="field-label">Back</div><input class="small-input" type="number" name="system.armor.back.value" value="{{mythicVehicleSystem.armor.back.value}}" /></div>
              <div class="compact-field"><div class="field-label">Side</div><input class="small-input" type="number" name="system.armor.side.value" value="{{mythicVehicleSystem.armor.side.value}}" /></div>
              <div class="compact-field"><div class="field-label">Top</div><input class="small-input" type="number" name="system.armor.top.value" value="{{mythicVehicleSystem.armor.top.value}}" /></div>
              <div class="compact-field"><div class="field-label">Bottom</div><input class="small-input" type="number" name="system.armor.bottom.value" value="{{mythicVehicleSystem.armor.bottom.value}}" /></div>
            </div>
          </div>
          {{/if}}

          <div class="panel shields-panel">
            <h3>Shields</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Integrity</div><input class="small-input" type="number" name="system.shields.value" value="{{mythicVehicleSystem.shields.value}}" /></div>
              <div class="compact-field"><div class="field-label">Delay</div><input class="small-input" type="number" name="system.shields.delay" value="{{mythicVehicleSystem.shields.delay}}" /></div>
              <div class="compact-field"><div class="field-label">Recharge</div><input class="small-input" type="number" name="system.shields.recharge" value="{{mythicVehicleSystem.shields.recharge}}" /></div>
            </div>
          </div>

          {{#if mythicVehicleIsWalker}}
          <div class="panel movement-panel vehicle-walker-characteristics-panel">
            <h3>Characteristics</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Strength</div><input class="small-input" type="number" name="system.characteristics.str" value="{{mythicVehicleSystem.characteristics.str}}" /></div>
              <div class="compact-field"><div class="field-label">Agility</div><input class="small-input" type="number" name="system.characteristics.agi" value="{{mythicVehicleSystem.characteristics.agi}}" /></div>
              <div class="compact-field"><div class="field-label">Jump</div><input class="small-input" type="number" min="0" step="0.1" name="system.movement.walker.jump" value="{{mythicVehicleSystem.movement.walker.jump}}" /></div>
              <div class="vehicle-walker-flex-break" aria-hidden="true"></div>
              <div class="compact-field"><div class="field-label">Mythic STR</div><input class="small-input" type="number" name="system.characteristics.mythicStr" value="{{mythicVehicleSystem.characteristics.mythicStr}}" /></div>
              <div class="compact-field"><div class="field-label">Mythic AGI</div><input class="small-input" type="number" name="system.characteristics.mythicAgi" value="{{mythicVehicleSystem.characteristics.mythicAgi}}" /></div>
              <div class="compact-field"><div class="field-label">Leap</div><input class="small-input" type="number" min="0" step="0.1" name="system.movement.walker.leap" value="{{mythicVehicleSystem.movement.walker.leap}}" /></div>
            </div>
          </div>
          {{else}}
          <div class="panel movement-panel">
            <h3>Movement</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Accelerate</div><input class="small-input" type="number" name="system.movement.accelerate.value" value="{{mythicVehicleSystem.movement.accelerate.value}}" /></div>
              <div class="compact-field"><div class="field-label">Brake</div><input class="small-input" type="number" name="system.movement.brake.value" value="{{mythicVehicleSystem.movement.brake.value}}" /></div>
              <div class="compact-field"><div class="field-label">Top Speed</div><input class="small-input" type="number" name="system.movement.speed.max" value="{{mythicVehicleSystem.movement.speed.max}}" /></div>
              <div class="compact-field"><div class="field-label">Maneuver</div><input class="small-input" type="number" name="system.movement.maneuver.total" value="{{mythicVehicleSystem.movement.maneuver.total}}" /></div>
            </div>
          </div>
          {{/if}}

          {{#if mythicVehicleIsWalker}}
          <div class="panel vehicle-walker-melee-panel">
            <h3>Walker Melee</h3>
            <div class="vehicle-walker-melee-setup">
              {{#if mythicVehicleWalker.melee.hasPunch}}
              <div class="vehicle-walker-melee-block">
                <div class="vehicle-walker-melee-block-label">Punch</div>
                <div class="vehicle-walker-melee-formula-row">
                  <input class="small-input" type="number" min="0" max="99" step="1" name="system.walker.melee.punch.diceCount" value="{{mythicVehicleWalker.melee.punch.diceCount}}" />
                  <select class="small-input" name="system.walker.melee.punch.diceSize">
                    {{selectOptions mythicVehicleWalker.melee.dieSizeOptions selected=mythicVehicleWalker.melee.punch.diceSize}}
                  </select>
                  <select class="vehicle-walker-melee-modifier-select" name="system.walker.melee.punch.modifier">
                    {{selectOptions mythicVehicleWalker.melee.modifierOptions selected=mythicVehicleWalker.melee.punch.modifier}}
                  </select>
                </div>
              </div>
              {{/if}}
              <div class="vehicle-walker-melee-block">
                <div class="vehicle-walker-melee-block-label">Stomp</div>
                <div class="vehicle-walker-melee-formula-row">
                  <input class="small-input" type="number" min="0" max="99" step="1" name="system.walker.melee.stomp.diceCount" value="{{mythicVehicleWalker.melee.stomp.diceCount}}" />
                  <select class="small-input" name="system.walker.melee.stomp.diceSize">
                    {{selectOptions mythicVehicleWalker.melee.dieSizeOptions selected=mythicVehicleWalker.melee.stomp.diceSize}}
                  </select>
                  <input class="small-input" type="number" value="{{mythicVehicleWalker.melee.stomp.modifierValue}}" readonly />
                </div>
              </div>
            </div>
          </div>
          {{/if}}

          <div class="panel propulsion-panel">
            <h3>Propulsion</h3>
            <div class="compact-row">
              <div style="min-width:160px;">
                <label>Type
                  <select name="system.propulsion.type">
                    {{selectOptions mythicPropulsionTypeOptions selected=mythicVehicleSystem.propulsion.type}}
                  </select>
                </label>
              </div>
              {{#if mythicShowPropulsionMaxField}}
              <div class="compact-field">
                <div class="field-label">Total</div>
                <select class="small-input" name="system.propulsion.max">
                  {{selectOptions mythicPropulsionMaxOptions selected=mythicVehicleSystem.propulsion.max}}
                </select>
              </div>
              {{else}}
              <input type="hidden" name="system.propulsion.max" value="" />
              {{/if}}
              {{#if mythicVehicleIsWalker}}
              <div class="compact-field">
                <div class="field-label">Arms</div>
                <input class="small-input" type="number" min="0" max="20" step="1" name="system.walker.armCount" value="{{mythicVehicleSystem.walker.armCount}}" />
              </div>
              {{/if}}
            </div>
          </div>

          <div class="panel size-panel">
            <h3>Size and Weapon Points</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Size</div>
                <input class="small-input" type="number" name="system.sizePoints" value="{{mythicVehicleSystem.sizePoints}}" min="0" max="99" step="1" style="width:56px;" />
              </div>
              <div class="compact-field"><div class="field-label">Weapon</div><input class="small-input" type="number" name="system.weaponPoints" value="{{mythicVehicleSystem.weaponPoints}}" /></div>
              {{#if mythicVehicleIsWalker}}
              <div class="compact-field">
                <div class="field-label">Size Category</div>
                <select class="vehicle-size-category-select" name="system.walker.sizeCategory">
                  {{selectOptions mythicVehicleSizeCategoryOptions selected=mythicVehicleSystem.walker.sizeCategory}}
                </select>
              </div>
              <div class="compact-field">
                <div class="field-label">Reach</div>
                <input class="small-input" type="number" name="system.walker.reach" value="{{mythicVehicleSystem.walker.reach}}" min="0" max="99" step="1" />
              </div>
              {{/if}}
            </div>
          </div>

          <div class="panel crew-panel">
            <h3>Crew & Complement</h3>
            <div class="compact-row">
              <div class="compact-field"><div class="field-label">Operators</div><input class="small-input" type="number" min="0" step="1" name="system.crew.capacity.operators" value="{{mythicVehicleSystem.crew.capacity.operators}}" /></div>
              <div class="compact-field"><div class="field-label">Gunners</div><input class="small-input" type="number" min="0" step="1" name="system.crew.capacity.gunners" value="{{mythicVehicleSystem.crew.capacity.gunners}}" /></div>
              <div class="compact-field"><div class="field-label">Passengers</div><input class="small-input" type="number" min="0" step="1" name="system.crew.capacity.passengers" value="{{mythicVehicleSystem.crew.capacity.passengers}}" /></div>
            </div>
            <p class="vehicle-loadout-note">Crew & Complement creates numbered slots from these counts.</p>
          </div>

          <div class="panel vehicle-weapon-systems-panel">
            <h3>Weapon Systems</h3>
            <div class="vehicle-weapon-systems-grid">
              <label class="vehicle-weapon-systems-field">
                <span class="field-label">Ammo Tracking</span>
                <select class="small-input" name="system.vehicle.ammoTrackingMode">
                  {{selectOptions mythicVehicleAmmoTrackingOptions selected=mythicVehicleSystem.vehicle.ammoTrackingMode}}
                </select>
              </label>
              <label class="vehicle-weapon-systems-toggle" for="vehicle-{{actor.id}}-autoloader-enabled">
                <input type="hidden" name="system.vehicle.autoloader.enabled" value="false" />
                <input id="vehicle-{{actor.id}}-autoloader-enabled" type="checkbox" name="system.vehicle.autoloader.enabled" value="true" {{#if mythicVehicleSystem.vehicle.autoloader.enabled}}checked{{/if}} />
                <span>Autoloader Enabled</span>
              </label>
            </div>
            <p class="vehicle-loadout-note">Standard tracks 5 magazines or batteries per mounted weapon. Autoloader swaps immediately in the UI and chat; table timing stays manual.</p>
          </div>
        </div>

        <div style="margin-top:12px;">
          <h3>Special Rules</h3>
          <div class="special-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; font-size:12px;">
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.allTerrain.has" value="false" />
              <input id="special-{{actor.id}}-allTerrain-has" type="checkbox" name="system.special.allTerrain.has" value="true" {{#if mythicVehicleSystem.special.allTerrain.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-allTerrain-has">All-Terrain</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.antiGrav.has" value="false" />
              <input id="special-{{actor.id}}-antiGrav-has" type="checkbox" name="system.special.antiGrav.has" value="true" {{#if mythicVehicleSystem.special.antiGrav.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-antiGrav-has">Anti-Gravitational</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.autoloader.has" value="false" />
              <input id="special-{{actor.id}}-autoloader-has" type="checkbox" name="system.special.autoloader.has" value="true" {{#if mythicVehicleSystem.special.autoloader.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-autoloader-has">Autoloader</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.boost.has" value="false" />
              <input id="special-{{actor.id}}-boost-has" type="checkbox" name="system.special.boost.has" value="true" {{#if mythicVehicleSystem.special.boost.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-boost-has">Boost</label>
              <input class="small-input" type="number" name="system.special.boost.value" value="{{mythicVehicleSystem.special.boost.value}}" min="0" max="9" step="1" style="width:30px;margin-left:6px;" />
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.continuousTrack.has" value="false" />
              <input id="special-{{actor.id}}-continuousTrack-has" type="checkbox" name="system.special.continuousTrack.has" value="true" {{#if mythicVehicleSystem.special.continuousTrack.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-continuousTrack-has">Continuous Track</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.enclosedTop.has" value="false" />
              <input id="special-{{actor.id}}-enclosedTop-has" type="checkbox" name="system.special.enclosedTop.has" value="true" {{#if mythicVehicleSystem.special.enclosedTop.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-enclosedTop-has">Enclosed-Top</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.flight.has" value="false" />
              <input id="special-{{actor.id}}-flight-has" type="checkbox" name="system.special.flight.has" value="true" {{#if mythicVehicleSystem.special.flight.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-flight-has">Flight</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.heavyPlating.has" value="false" />
              <input id="special-{{actor.id}}-heavyPlating-has" type="checkbox" name="system.special.heavyPlating.has" value="true" {{#if mythicVehicleSystem.special.heavyPlating.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-heavyPlating-has">Heavy Plating</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.neuralInterface.has" value="false" />
              <input id="special-{{actor.id}}-neuralInterface-has" type="checkbox" name="system.special.neuralInterface.has" value="true" {{#if mythicVehicleSystem.special.neuralInterface.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-neuralInterface-has">Neural Interface</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.openTop.has" value="false" />
              <input id="special-{{actor.id}}-openTop-has" type="checkbox" name="system.special.openTop.has" value="true" {{#if mythicVehicleSystem.special.openTop.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-openTop-has">Open-Top</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.slipspace.has" value="false" />
              <input id="special-{{actor.id}}-slipspace-has" type="checkbox" name="system.special.slipspace.has" value="true" {{#if mythicVehicleSystem.special.slipspace.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-slipspace-has">Slipspace Travel</label>
            </div>
            <div style="display:flex;align-items:center;gap:6px;">
              <input type="hidden" name="system.special.walkerStomp.has" value="false" />
              <input id="special-{{actor.id}}-walkerStomp-has" type="checkbox" name="system.special.walkerStomp.has" value="true" {{#if mythicVehicleSystem.special.walkerStomp.has}}checked{{/if}} />
              <label for="special-{{actor.id}}-walkerStomp-has">Walker Stomp</label>
            </div>
          </div>
        </div>

        <div class="panel mythic-sheet-appearance-card mythic-sheet-appearance-card-wide">
          <h3>Sheet Appearance</h3>
          {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/sheet-appearance-fields.hbs"}}
        </div>
      </div>
    </div>
  </section>
</div>
{{else}}
<div
  class="mythic-character-sheet mythic-sheet-theme-root"
  data-faction="{{mythicFactionIndex}}"
  data-theme-preset="{{mythicSheetAppearance.preset}}"
  data-panel-style="{{mythicSheetAppearance.panelStyle}}"
  data-portrait-frame="{{mythicSheetAppearance.portraitFrame}}"
  data-banner-style="{{mythicSheetAppearance.banner.style}}"
  data-has-banner="{{#if mythicSheetAppearance.displayBanner}}true{{else}}false{{/if}}">
  <aside class="sheet-nav">
    <nav class="sheet-tabs tabs" data-group="primary">
      <a class="item" data-tab="main" title="Main">
        <i class="fas fa-user"></i>
      </a>
      <a class="item" data-tab="skills" title="Skills &amp; Educations">
        <i class="fas fa-list"></i>
      </a>
      <a class="item" data-tab="abilities" title="Abilities">
        <i class="fas fa-bolt"></i>
      </a>
      <a class="item" data-tab="equipment" title="Inventory">
        <i class="fas fa-toolbox"></i>
      </a>
      <a class="item" data-tab="medical" title="Medical">
        <i class="fas fa-heart-pulse"></i>
      </a>
      <a class="item" data-tab="advancements" title="Character Creation and Advancement">
        <i class="fas fa-arrow-trend-up"></i>
      </a>
      <a class="item" data-tab="notes" title="Notes">
        <i class="fas fa-note-sticky"></i>
      </a>
      <a class="item" data-tab="biography" title="Biography">
        <i class="fas fa-book-open"></i>
      </a>
      <a class="item" data-tab="vehicles" title="Vehicles">
        <i class="fas fa-truck"></i>
      </a>
      <a class="item" data-tab="setup" title="Settings">
        <i class="fas fa-gear"></i>
      </a>
    </nav>
  </aside>

  <section class="sheet-content">
    {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/header.hbs"}}
    <div class="sheet-tab-scrollable">
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/main-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/skills-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/abilities-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/equipment-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/medical-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/advancements-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/notes-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/biography-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/vehicles-tab.hbs"}}
      {{> "systems/Halo-Mythic-Foundry-Updated/templates/actor/parts/setup-tab.hbs"}}
    </div>
  </section>
</div>
{{/if}}
